# Brevo (Sendinblue) API key, used server-side only by src/pages/api/subscribe.ts
# to call Brevo's double opt-in endpoint. Get this from Brevo > Settings > API Keys.
#
# NEVER commit a real key to this file or any tracked file — .env.example only
# documents which variables are required. Put the real value in a local .env
# (already gitignored) for local dev, and in your Netlify site's
# Site settings > Environment variables for production.
BREVO_API_KEY=your_brevo_api_key_here
