---
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { clusters, getCluster, getCalculatorsForCluster } from '../../data/calculators';

export function getStaticPaths() {
  return clusters.map((cluster) => ({
    params: { cluster: cluster.slug },
    props: { cluster },
  }));
}

const { cluster } = Astro.props;
const clusterCalculators = getCalculatorsForCluster(cluster.slug);
const liveCalculators = clusterCalculators.filter((c) => c.status === 'live');
const plannedCalculators = clusterCalculators.filter((c) => c.status === 'coming-soon');

const iconPaths: Record<string, string> = {
  soil: 'M3 14h18M5 14l1.5-5h13L21 14M5 14v5h14v-5',
  fertilizer: 'M12 3v18M8 7l4-4 4 4M7 12h10M6 17h12',
  water: 'M12 3c3 4 5 7 5 10a5 5 0 0 1-10 0c0-3 2-6 5-10Z',
  spacing: 'M4 4h16v16H4zM4 10h16M4 16h16M10 4v16M16 4v16',
  lawn: 'M4 20h16M6 20v-6M10 20v-8M14 20v-6M18 20v-10M4 8l4-3 4 3 4-3 4 3',
  indoor: 'M12 3v18M5 8h14M5 8c0 5 3 8 7 8s7-3 7-8',
  hydro: 'M12 3v18M5 7h14v6H5zM7 13v4h10v-4',
  tree: 'M12 2c-3 4-6 8-6 12a6 6 0 0 0 12 0c0-4-3-8-6-12ZM12 22v-6',
};

// The Soil & Amendments and Lawn & Landscaping clusters have been built out
// into genuine content pillars (original written guide + calculator
// directory), not just listing pages. Other clusters keep the plain
// directory layout for now.
const isSoilPillar = cluster.slug === 'soil-and-amendments';
const isLawnPillar = cluster.slug === 'lawn-and-landscaping';
const isIndoorPillar = cluster.slug === 'indoor-plants';
const isPillar = isSoilPillar || isLawnPillar || isIndoorPillar;


// TOC + sticky-sidebar layout (same TableOfContents component used on
// calculator pages) -- each pillar cluster gets its own set of anchors.
const soilTocItems = [
  { id: 'live-calculators', label: 'Live Calculators' },
  { id: 'choosing-the-right-material', label: 'Choosing the Right Material' },
  { id: 'filling-a-raised-bed', label: 'Filling a Raised Bed' },
  { id: 'mulching-and-top-dressing', label: 'Mulching and Top-Dressing' },
  { id: 'composting-basics', label: 'Composting Basics' },
];

const lawnTocItems = [
  { id: 'live-calculators', label: 'Live Calculators' },
  { id: 'new-lawn-or-overseeding', label: 'New Lawn or Overseeding?' },
  { id: 'choosing-the-right-grass-type', label: 'Choosing the Right Grass Type' },
  { id: 'lawn-care-timing', label: 'Lawn Care Timing' },
];

const indoorTocItems = [
  { id: 'live-calculators', label: 'Live Calculators' },
  { id: 'how-much-light-does-your-plant-need', label: 'How Much Light?' },
  { id: 'choosing-the-right-pot-size', label: 'Choosing the Right Pot Size' },
  { id: 'quick-reference-light-and-pot-size', label: 'Quick Reference Table' },
  { id: 'when-to-reassess', label: 'When to Reassess' },
];

const pillarTocItems = isSoilPillar ? soilTocItems : isLawnPillar ? lawnTocItems : isIndoorPillar ? indoorTocItems : [];

// Depth-ruler data for the "at a glance" visual (point 2). Topsoil/Compost/
// Mulch ranges are the exact figures already stated in the prose below.
// Garden Soil has no single stated figure in the article (only "top layer
// of a bed"), so 2-4in is a labeled approximation for a typical
// topsoil-compost blend layer near the surface -- flagged as approx. in the
// UI rather than presented as a hard fact.
const depthScaleMax = 12;
const materialDepths = [
  {
    name: 'Topsoil',
    range: [8, 12] as const,
    approx: false,
    color: '#B8975C',
    bestFor: 'Bulk fill — leveling, grading, building volume under a bed',
    where: 'In the soil (fill layer, not for direct planting)',
  },
  {
    name: 'Garden Soil',
    range: [2, 4] as const,
    approx: true,
    color: '#6B4F35',
    bestFor: 'Anywhere you’re planting directly — seeds and transplants',
    where: 'In the soil (planting layer)',
  },
  {
    name: 'Compost',
    range: [1, 3] as const,
    approx: false,
    color: '#4A7C59',
    bestFor: 'Feeding soil already in place, or blended into a new mix (~30% of a new blend)',
    where: 'Both — blended in or top-dressed',
  },
  {
    name: 'Mulch',
    range: [2, 3] as const,
    approx: false,
    color: '#8B6535',
    bestFor: 'Moisture retention, weed suppression, temperature control',
    where: 'On top only, never mixed in',
  },
];

// Small material-tint lookup for the Live Calculators grid (point 3) --
// only the 5 Soil & Amendments calculators have a defined tint today;
// everything else falls back to plain white, so this is safe to apply to
// every cluster's grid without affecting the other 7.
const calculatorTint: Record<string, string> = {
  'topsoil-calculator': 'bg-[#B8975C]/10',
  'raised-bed-soil-calculator': 'bg-[#6B4F35]/10',
  'soil-volume-calculator': 'bg-moss-50',
  'mulch-calculator': 'bg-[#8B6535]/10',
  'compost-calculator': 'bg-[#4A7C59]/10',
  'grass-seed-calculator': 'bg-[#8B6535]/10',
  'overseeding-calculator': 'bg-[#4A7C59]/10',
  'grow-light-calculator': 'bg-[#E8A94A]/10',
  'pot-size-calculator': 'bg-[#8B6535]/10',
};

const soilPillarTitle = 'Soil & Amendments: Topsoil, Compost & Mulch Guide';
const soilPillarDescription =
  'The complete guide to topsoil, garden soil, compost, and mulch — what each one does, when to use it, and calculators for the exact amount.';

const lawnPillarTitle = 'Lawn & Landscaping: New Lawns, Overseeding, and Grass Type Guide';
const lawnPillarDescription =
  'The complete guide to establishing a new lawn from seed, overseeding an existing one, and choosing the right grass type for your climate — plus calculators for exact seed amounts.';

const indoorPillarTitle = 'Indoor Plants: Light, Pot Size & Houseplant Care Guide';
const indoorPillarDescription =
  'The complete guide to houseplant light needs and pot sizing — how much light your plant actually needs, when to size up its pot, and calculators for both.';

const pillarTitle = isSoilPillar ? soilPillarTitle : isLawnPillar ? lawnPillarTitle : isIndoorPillar ? indoorPillarTitle : '';
const pillarDescription = isSoilPillar ? soilPillarDescription : isLawnPillar ? lawnPillarDescription : isIndoorPillar ? indoorPillarDescription : '';
const pillarAboutName = isSoilPillar ? 'Soil and garden amendments' : isLawnPillar ? 'Lawn care and grass seeding' : isIndoorPillar ? 'Houseplant light and container care' : '';

const pageTitle = isPillar ? pillarTitle : `${cluster.name} Calculators`;
const pageDescription = isPillar ? pillarDescription : cluster.metaDescription;

const clusterUrl = new URL(`/clusters/${cluster.slug}/`, Astro.site).href;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: cluster.name, item: clusterUrl },
  ],
};

const collectionPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pillarTitle,
  description: pillarDescription,
  url: clusterUrl,
  about: { '@type': 'Thing', name: pillarAboutName },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: liveCalculators.map((calc, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: calc.title,
      url: new URL(calc.href, Astro.site).href,
    })),
  },
};

// Article schema for the pillar's own original written content (alongside
// the BreadcrumbList + CollectionPage/ItemList schema above) -- this is
// what makes each pillar page's guide content, not just its calculator
// directory, eligible for rich-result treatment as an article.
const pillarArticleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pillarTitle,
  description: pillarDescription,
  url: clusterUrl,
  author: { '@type': 'Organization', name: 'HarvestMath' },
  publisher: { '@type': 'Organization', name: 'HarvestMath' },
};

// Comparison table data for the Lawn & Landscaping pillar -- grounded in
// the exact rates already published on each calculator's own page (see
// GRASS_PRESETS in GrassSeedCalculator.tsx and GRASS_RATES in
// OverseedingCalculator.tsx), not separately invented numbers.
const lawnComparisonRows = [
  {
    label: 'Use when',
    grassSeed: 'Starting a lawn from bare soil, or a full renovation where old turf is removed first.',
    overseeding: 'Thickening a thin, patchy, or bare-spotted lawn that still has living turf in place.',
  },
  {
    label: 'Typical rate',
    grassSeed: '1.5–8 lb of seed per 1,000 sq ft depending on grass type — the full establishment rate.',
    overseeding: 'Roughly half the new-lawn rate as a baseline, scaled up further for patchier or barer lawns.',
  },
  {
    label: 'Key difference',
    grassSeed: 'Calculates a full rate — new seedlings have no existing turf competing with them for light, water, or nutrients.',
    overseeding: 'Calculates a reduced, condition-based rate — existing turf already covers part of the ground, so a full new-lawn rate wastes seed and can crowd out germinating seedlings.',
  },
];

// Quick-reference table for the Indoor Plants pillar -- light category
// follows well-established general houseplant-care classifications, and
// pot size ranges are pulled directly from CATEGORY_INFO in
// PotSizeCalculator.tsx (houseSmall/houseMed/houseLarge/succulent) so this
// table stays consistent with what the calculator itself shows.
const indoorReferenceRows = [
  { plant: 'Snake Plant', light: 'Low', potSize: '6–10 in (roughly 2–3 gal)' },
  { plant: 'Pothos', light: 'Low', potSize: '4–6 in' },
  { plant: 'Monstera', light: 'Medium', potSize: '6–10 in, sizing up to 10–14+ in as it matures' },
  { plant: 'Fiddle Leaf Fig', light: 'High', potSize: '10–14+ in (roughly 5–15 gal)' },
  { plant: 'ZZ Plant', light: 'Low', potSize: '6–10 in (roughly 2–3 gal)' },
  { plant: 'Succulents / Cacti', light: 'High', potSize: '2–4 in — a snug pot, not a large one' },
];
---

<Layout title={pageTitle} description={pageDescription} rawTitle={isPillar}>
  {isPillar && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} slot="head" />}
  {isPillar && <script type="application/ld+json" set:html={JSON.stringify(collectionPageJsonLd)} slot="head" />}
  {isPillar && <script type="application/ld+json" set:html={JSON.stringify(pillarArticleJsonLd)} slot="head" />}
  <section class="border-b border-moss-100 bg-moss-50/60">
    <div class="container-wide py-12 sm:py-16">
      <nav class="flex text-sm text-bark-500" aria-label="Breadcrumb">
        <a href="/" class="hover:text-moss-800">Home</a>
        <span class="mx-2">/</span>
        <span class="text-bark-700">{cluster.name}</span>
      </nav>

      {isPillar ? (
        <div class="mt-6 grid gap-8 lg:grid-cols-[1fr_380px] lg:items-center lg:gap-12">
          <div>
            <h1 class="font-display text-3xl font-semibold tracking-tight text-bark-900 sm:text-4xl lg:text-5xl">
              {cluster.name} Calculators
            </h1>
            <p class="mt-3 max-w-2xl text-base leading-relaxed text-bark-600 sm:text-lg">
              {cluster.description}
            </p>
          </div>
          <div class="mx-auto w-full max-w-sm lg:mx-0 lg:max-w-none">
            {isSoilPillar ? (
              <img
                src="/soil-and-amendments-cluster-cross-section.svg"
                alt="Cross-section of a raised bed showing mulch on top, garden soil beneath it, and bulk topsoil fill at the bottom"
                width="800"
                height="500"
                class="w-full rounded-2xl border border-[#5C4433]/15 bg-white shadow-card"
              />
            ) : isLawnPillar ? (
              <img
                src="/lawn-and-landscaping-cluster-new-vs-overseed.svg"
                alt="Split view of a lawn: bare soil being seeded with a spreader on the left, existing thin turf being overseeded on the right"
                width="800"
                height="500"
                class="w-full rounded-2xl border border-[#5C4433]/15 bg-white shadow-card"
              />
            ) : (
              <img
                src="/indoor-plants-cluster-window-and-pot-sizes.svg"
                alt="A houseplant in bright light beside a window, next to three nursery pots of increasing size showing pot-sizing progression"
                width="800"
                height="500"
                class="w-full rounded-2xl border border-[#5C4433]/15 bg-white shadow-card"
              />
            )}
          </div>
        </div>
      ) : (
        <div class="mt-6 flex items-start gap-5">
          <div class="hidden h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-moss-100 text-moss-700 sm:flex">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={iconPaths[cluster.icon] ?? iconPaths.soil} />
            </svg>
          </div>
          <div>
            <h1 class="font-display text-3xl font-semibold tracking-tight text-bark-900 sm:text-4xl lg:text-5xl">
              {cluster.name} Calculators
            </h1>
            <p class="mt-3 max-w-2xl text-base leading-relaxed text-bark-600 sm:text-lg">
              {cluster.description}
            </p>
          </div>
        </div>
      )}
    </div>
  </section>

  {isPillar && (
    <section class="container-wide py-12 sm:py-16">
      <div class="lg:grid lg:grid-cols-[1fr_240px] lg:gap-12">
        <div class="min-w-0">
          <TableOfContents items={pillarTocItems} variant="accordion" />

          <article class="prose prose-bark max-w-none prose-headings:font-display prose-headings:text-bark-900 prose-h2:mt-12 prose-h2:scroll-mt-24 prose-h2:text-2xl prose-h2:font-semibold prose-a:text-moss-700 prose-strong:text-bark-900">
        {isSoilPillar && (
          <>
        <p>
          Every raised bed, lawn repair, or new planting starts with the same question: what actually goes in the ground? Four materials do almost all of the work &mdash; topsoil, garden soil, compost, and mulch &mdash; and they are not interchangeable, even though garden centers sometimes blur the lines between them.
        </p>
        <p>
          Topsoil is unamended native soil, the uppermost layer of the ground with no compost or other organic matter added. It&rsquo;s a raw material, used mainly for bulk fill: leveling low spots, building volume under a raised bed, or grading before sod goes down. Garden soil starts from topsoil and adds compost and other organic matter specifically so plants can root and grow in it &mdash; it&rsquo;s the material that actually goes where seeds and transplants will live. Compost is a soil amendment in its own right: fully decomposed organic matter that feeds soil biology and improves structure, whether it&rsquo;s blended into a bed at planting time or spread as a thin top-dressing on an established one. Mulch sits on top of the soil rather than in it &mdash; bark, wood chips, or a similar material spread over the surface to hold moisture, block weeds, and moderate soil temperature.
        </p>
        <p>
          A real project usually uses more than one of these in sequence. A new raised bed gets filled with bulk topsoil for depth, then a topsoil-compost blend near the surface for planting; compost gets worked in seasonally to keep feeding the soil; mulch goes on top once everything&rsquo;s planted to cut down on watering and weeding. Knowing which material does which job &mdash; and how much of it you actually need &mdash; is most of what separates a bed that thrives from one that fights you all season. That&rsquo;s what the tools and guides below are built to answer.
        </p>
          </>
        )}

        {isLawnPillar && (
          <>
        <p>
          A great lawn starts with one decision: are you building it from scratch, or fixing one that already exists? Starting a <strong>new lawn</strong> means bare soil, no competition, and a full seeding rate to establish turf from nothing. <strong>Overseeding</strong> means working seed into an existing lawn that already has living grass in place &mdash; thickening thin turf, filling bare patches, or repairing damage &mdash; at a reduced rate, since the existing grass is already covering part of the ground.
        </p>
        <p>
          Grass type matters just as much as which of those two situations you&rsquo;re in. Cool-season and warm-season grasses germinate at different soil temperatures, thrive in different climates, and go dormant at different times of year &mdash; using the wrong species for your climate, or seeding at the wrong time of year for your species, wastes seed regardless of how precisely you calculate the amount. A full-season lawn care approach treats seeding (new or over-) as one step in a cycle that also includes mowing height, fertilizing, and seasonal timing &mdash; the calculators below handle the seed math; the guidance around them is built to get the timing and species choice right too.
        </p>
          </>
        )}

        {isIndoorPillar && (
          <>
        <p>
          Healthy houseplants come down to two main levers: <strong>light</strong> and <strong>container</strong>. Get the light wrong and a plant stalls out, stretches toward the window, or drops leaves no matter how well you water it. Get the pot wrong &mdash; too small for too long, or sized up too aggressively &mdash; and roots either strangle themselves or sit in more soil than they can use, inviting root rot. Everything else in houseplant care (watering schedule, fertilizing, humidity) matters too, but it&rsquo;s downstream of getting these two right first.
        </p>
        <p>
          This cluster&rsquo;s two calculators address each lever directly. The <a href="/calculators/grow-light-calculator/">Grow Light &amp; DLI Calculator</a> turns a light reading (or a general sense of how bright a spot is) into a concrete number &mdash; Daily Light Integral &mdash; you can compare against what your plant actually needs. The <a href="/calculators/pot-size-calculator/">Pot Size Calculator</a> converts between pot sizing conventions and tells you the recommended next size up when it&rsquo;s time to repot. Used together, they replace a lot of guesswork with two numbers you can actually check your plant against.
        </p>
          </>
        )}

        <div class="not-prose my-6 flex flex-wrap items-center gap-x-2 gap-y-3 rounded-xl border border-[#5C4433]/15 bg-white p-4">
          <span class="mr-1 text-sm font-semibold text-bark-500">Jump to a calculator:</span>
          {liveCalculators.map((calc) => (
            <a
              href={calc.href}
              class="inline-flex items-center rounded-full bg-moss-50 px-3.5 py-1.5 text-sm font-medium text-moss-800 ring-1 ring-moss-200 transition hover:bg-moss-100 hover:text-moss-900"
            >
              {calc.shortTitle}
            </a>
          ))}
        </div>

        {isSoilPillar && (
          <div class="not-prose my-8 rounded-xl border border-[#5C4433]/15 bg-white p-6 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wider text-bark-400">Typical depth, side by side</p>
            <div class="mt-4 space-y-5">
              {materialDepths.map((m) => {
                const leftPct = (m.range[0] / depthScaleMax) * 100;
                const widthPct = ((m.range[1] - m.range[0]) / depthScaleMax) * 100;
                return (
                  <div>
                    <div class="flex items-baseline justify-between gap-4">
                      <span class="font-display text-sm font-semibold text-bark-900">{m.name}</span>
                      <span class="text-xs text-bark-500">{m.range[0]}&ndash;{m.range[1]} in{m.approx ? ' (approx.)' : ''}</span>
                    </div>
                    <div class="relative mt-1.5 h-3 rounded-full bg-bark-50">
                      <div
                        class="absolute inset-y-0 rounded-full"
                        style={`left:${leftPct}%; width:${widthPct}%; background-color:${m.color}`}
                      />
                    </div>
                    <p class="mt-1.5 text-xs leading-relaxed text-bark-500">{m.bestFor} &mdash; {m.where}</p>
                  </div>
                );
              })}
            </div>
            <div class="mt-4 flex justify-between text-[11px] text-bark-400">
              <span>0&Prime;</span><span>3&Prime;</span><span>6&Prime;</span><span>9&Prime;</span><span>12&Prime;</span>
            </div>
          </div>
        )}

        {isLawnPillar && (
          <div class="not-prose my-8 overflow-x-auto rounded-xl border border-[#5C4433]/15 bg-white p-6 shadow-sm">
            <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-bark-400">Grass Seed vs. Overseeding, side by side</p>
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="border-b border-moss-100 text-bark-500">
                  <th scope="col" class="py-2 pr-4 font-medium"></th>
                  <th scope="col" class="py-2 pr-4 font-medium">Grass Seed Calculator</th>
                  <th scope="col" class="py-2 font-medium">Overseeding Calculator</th>
                </tr>
              </thead>
              <tbody class="text-bark-700">
                {lawnComparisonRows.map((row, i) => (
                  <tr class={i < lawnComparisonRows.length - 1 ? 'border-b border-moss-50 align-top' : 'align-top'}>
                    <th scope="row" class="py-3 pr-4 font-semibold text-bark-800">{row.label}</th>
                    <td class="py-3 pr-4 leading-relaxed text-bark-600">{row.grassSeed}</td>
                    <td class="py-3 leading-relaxed text-bark-600">{row.overseeding}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {liveCalculators.length > 0 && (
          <div id="live-calculators" class="not-prose scroll-mt-24">
            <h2 class="font-display text-2xl font-semibold text-bark-900">Live calculators</h2>
            <p class="mt-2 text-sm text-bark-600">Ready to use right now.</p>
            <div class="mt-6 grid gap-5 sm:grid-cols-2">
              {liveCalculators.map((calc) => (
                <a
                  href={calc.href}
                  class={`group flex flex-col gap-2 rounded-2xl ${calculatorTint[calc.slug] ?? 'bg-white'} p-6 shadow-card ring-1 ring-moss-100/60 transition hover:-translate-y-0.5 hover:shadow-cardHover`}
                >
                  <span class="text-xs font-medium uppercase tracking-wider text-moss-600">Live</span>
                  <h3 class="font-display text-lg font-semibold text-bark-900 group-hover:text-moss-800">
                    {calc.title}
                  </h3>
                  <p class="text-sm leading-relaxed text-bark-600">{calc.description}</p>
                  <span class="mt-auto inline-flex items-center text-sm font-medium text-moss-700">
                    Open
                    <svg class="ml-1 h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </a>
              ))}
            </div>
          </div>
        )}

        {plannedCalculators.length > 0 && (
          <div class={liveCalculators.length > 0 ? 'not-prose mt-12' : 'not-prose'}>
            <h2 class="font-display text-2xl font-semibold text-bark-900">Coming soon</h2>
            <p class="mt-2 text-sm text-bark-600">In the queue &mdash; these are next on the build list.</p>
            <div class="mt-6 grid gap-5 sm:grid-cols-2">
              {plannedCalculators.map((calc) => (
                <div class="flex flex-col gap-2 rounded-2xl bg-sand-50 p-6 ring-1 ring-moss-100/40">
                  <span class="text-xs font-medium uppercase tracking-wider text-bark-400">Coming soon</span>
                  <h3 class="font-display text-lg font-semibold text-bark-700">{calc.title}</h3>
                  <p class="text-sm leading-relaxed text-bark-500">{calc.description}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {isSoilPillar && (
          <>
        <h2 id="choosing-the-right-material">Choosing the Right Material</h2>
        <p>
          The short version: use <strong>topsoil</strong> for bulk fill where roots won&rsquo;t be growing directly &mdash; leveling, grading, building volume under a bed. Use <strong>garden soil</strong> (topsoil blended with compost) anywhere you&rsquo;re planting directly, since straight topsoil alone compacts too hard and holds too few nutrients for most vegetables and ornamentals. Use <strong>compost</strong> on its own when you&rsquo;re feeding soil that&rsquo;s already in place &mdash; worked into the top few inches of an existing bed, or blended into new soil at a lower ratio than a full garden-soil mix.
        </p>
        <p>
          For the full breakdown, including a side-by-side comparison and specific blend ratios, see our <a href="/blog/topsoil-vs-garden-soil/">complete guide to topsoil vs. garden soil</a>. Once you know which material you need, the <a href="/calculators/topsoil-calculator/">Topsoil Calculator</a> and <a href="/calculators/raised-bed-soil-calculator/">Raised Bed Soil Calculator</a> convert your area and depth into the cubic yards, tons, or bags you&rsquo;ll actually order.
        </p>

        <h2 id="filling-a-raised-bed">Filling a Raised Bed</h2>
        <p>
          Depth is the first decision: most raised beds want 8&ndash;12 inches of soil, though shallow crops can get away with less if the bed sits on native ground rather than a hard surface. From there it&rsquo;s a volume problem &mdash; length &times; width &times; depth, converted into whatever unit your supplier quotes in.
        </p>
        <p>
          The <a href="/calculators/raised-bed-soil-calculator/">Raised Bed Soil Calculator</a> handles standard bed sizes and the topsoil-compost-perlite blend ratio directly. For containers, pots, or any bed that isn&rsquo;t a simple rectangle, the <a href="/calculators/soil-volume-calculator/">Soil Volume Calculator</a> covers rectangular and cylindrical spaces alike, including irregular footprints you can break into simpler shapes.
        </p>

        <h2 id="mulching-and-top-dressing">Mulching and Top-Dressing</h2>
        <p>
          Once a bed is planted, both mulch and compost can go on top of the soil rather than into it &mdash; mulch mainly for moisture retention and weed suppression, compost top-dressing to feed soil biology without disturbing roots. A standard mulch layer is 2&ndash;3 inches of bark or wood chips, kept a few inches clear of any trunk or stem. A compost top-dressing is thinner, usually 1&ndash;3 inches, since it&rsquo;s meant to be worked in gently rather than piled deep.
        </p>
        <p>
          The <a href="/calculators/mulch-calculator/">Mulch Calculator</a> converts your bed size and depth into cubic yards and bags for a mulch layer. We&rsquo;re also working on a dedicated guide comparing organic mulches like bark and wood chips against inorganic options like rubber and stone &mdash; check back soon.
        </p>

        <h2 id="composting-basics">Composting Basics</h2>
        <p>
          Finished compost is fully decomposed organic matter &mdash; dark, crumbly, and earthy-smelling &mdash; that improves soil structure and feeds plant-available nutrients as it continues breaking down. It&rsquo;s built from a rough mix of nitrogen-rich &ldquo;greens&rdquo; (kitchen scraps, fresh grass clippings) and carbon-rich &ldquo;browns&rdquo; (dry leaves, cardboard, straw), generally 2&ndash;3 parts browns to 1 part greens by volume. Unfinished compost &mdash; still actively decomposing &mdash; should go into the soil weeks before planting, not right at transplant time, since the decomposition process temporarily ties up soil nitrogen.
        </p>
        <p>
          Compost gets used two ways in this cluster: blended into new bed soil at roughly 30% of the total volume, or top-dressed onto an existing bed at 1&ndash;3 inches. The <a href="/calculators/compost-calculator/">Compost Calculator</a> handles both, along with bag counts and estimated weight for whatever you&rsquo;re hauling.
        </p>
          </>
        )}

        {isLawnPillar && (
          <>
        <h2 id="new-lawn-or-overseeding">New Lawn or Overseeding?</h2>
        <p>
          These are two different jobs with two different rates, and mixing them up is the single most common seeding mistake. A <strong>new lawn</strong> starts from bare soil &mdash; tilled ground, a torn-out old lawn, or a brand-new construction lot &mdash; with nothing already growing to compete with new seedlings, so it needs a full establishment rate. <strong>Overseeding</strong> works seed into a lawn that already has living turf in place, whether it&rsquo;s thin, patchy, or just due for a thickness boost &mdash; since the existing grass already covers part of the ground, it needs roughly half the new-lawn rate, scaled up if the lawn is thinner or barer.
        </p>

        <div class="not-prose my-8 grid gap-5 sm:grid-cols-2">
          <a
            href="/calculators/grass-seed-calculator/"
            class="group flex flex-col gap-2 rounded-2xl bg-white p-6 shadow-card ring-1 ring-moss-100/60 transition hover:-translate-y-0.5 hover:shadow-cardHover"
          >
            <span class="text-xs font-medium uppercase tracking-wider text-moss-600">New lawn</span>
            <h3 class="font-display text-lg font-semibold text-bark-900 group-hover:text-moss-800">Grass Seed Calculator</h3>
            <p class="text-sm leading-relaxed text-bark-600">Starting from bare soil? Get the full establishment rate in pounds and bags for your grass type.</p>
            <span class="mt-auto inline-flex items-center text-sm font-medium text-moss-700">
              Open
              <svg class="ml-1 h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </a>
          <a
            href="/calculators/overseeding-calculator/"
            class="group flex flex-col gap-2 rounded-2xl bg-white p-6 shadow-card ring-1 ring-moss-100/60 transition hover:-translate-y-0.5 hover:shadow-cardHover"
          >
