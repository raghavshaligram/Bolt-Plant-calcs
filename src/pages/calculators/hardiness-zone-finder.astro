---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import HardinessZoneFinder from '../../components/calculators/HardinessZoneFinder.tsx';
import TableOfContents from '../../components/TableOfContents.astro';
import LeadMagnetForm from '../../components/LeadMagnetForm.jsx';
import FAQBlock from '../../components/FAQBlock.astro';
import RelatedCalculatorsList from '../../components/RelatedCalculatorsList.astro';
import { getCalculator, getCluster, leadMagnetConfig } from '../../data/calculators';
import { ZONE_TEMP_BANDS, formatTempRangeF, formatTempRangeC } from '../../lib/hardinessZoneTemps';

const calculator = getCalculator('hardiness-zone-finder')!;
const cluster = getCluster(calculator.cluster)!;
const leadMagnet = leadMagnetConfig[cluster.slug]!;

const lastUpdated = '2026-07-16';
const formattedDate = new Date(lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const authorName = 'HarvestMath Editors';
const authorUrl = '/about/';

const intro =
  'This USDA hardiness zone finder answers one specific question: what USDA plant hardiness zone am I in? USDA plant hardiness zones are the standard reference for winter plant survival across the US, and entering your ZIP code below matches you to yours along with the average annual minimum winter temperature that zone represents — the same rating printed on every "hardy to zone X" plant tag.';

const tocItems = [
  { id: 'what-is-a-usda-hardiness-zone', label: 'What Is a Hardiness Zone?', icon: 'leaf' as const },
  { id: 'zone-reference-table', label: 'Zone Reference Table', icon: 'table' as const },
  { id: 'worked-example', label: 'Worked Example', icon: 'table' as const },
  { id: 'why-your-zone-matters', label: 'Why Your Zone Matters', icon: 'leaf' as const },
  { id: 'common-mistakes', label: 'Common Mistakes', icon: 'warning' as const },
  { id: 'hardiness-zone-finder-faq', label: 'FAQ', icon: 'question' as const },
  { id: 'related-calculators', label: 'Related Calculators', icon: 'grid' as const },
];

const shareImage = new URL('/hardiness-zone-finder-zone-gradient.svg', Astro.site).href;

const zoneTableRows = [
  '3a', '3b', '4a', '4b', '5a', '5b', '6a', '6b', '7a', '7b', '8a', '8b',
  '9a', '9b', '10a', '10b', '11a', '11b',
];

const faqs = [
  {
    q: 'What does Zone 5 mean in gardening?',
    a: 'Zone 5 means the area’s average annual minimum winter temperature falls between -20°F and -10°F (split into 5a and 5b). It tells you which perennials, shrubs, and trees are rated to survive winter there — a plant labeled "hardy to zone 5" should survive that cold without special protection.',
  },
  {
    q: 'What is the purpose of USDA hardiness zones?',
    a: 'USDA hardiness zones exist to give gardeners a standardized way to judge whether a perennial plant will survive winter in their area. Every zone reflects average annual minimum winter temperature only — it’s a survival rating, not a full description of a region’s climate.',
  },
  {
    q: 'Is there a European equivalent of US hardiness zones?',
    a: 'The Royal Horticultural Society (RHS) publishes its own hardiness rating system for the UK, and much of Europe references either the RHS system or an adapted version of the USDA scale. The underlying concept — rating plants against average annual minimum temperature — is the same, but the exact zone numbers and boundaries differ between systems, so a "zone 7" label isn’t automatically the same in both.',
  },
  {
    q: 'How do I look up my hardiness zone by ZIP code?',
    a: 'Enter your ZIP code into the calculator above for a fast regional estimate, matched to the nearest of a set of real reference points in your state. For the official, address-level zone, check the USDA’s own Plant Hardiness Zone Map directly at planthardiness.ars.usda.gov.',
  },
];

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Find your USDA plant hardiness zone by ZIP code',
  description:
    'Use the hardiness zone finder to look up your USDA Plant Hardiness Zone and its average annual minimum winter temperature range by ZIP code.',
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Enter your ZIP code',
      text: 'Enter your 5-digit US ZIP code.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Read your USDA hardiness zone',
      text: 'Read your estimated USDA Plant Hardiness Zone.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Check the temperature range',
      text: 'Check the average annual minimum winter temperature range that zone represents.',
    },
  ],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://harvestmath.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Spacing & Planting',
      item: 'https://harvestmath.com/clusters/spacing-and-planting/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Hardiness Zone Finder',
      item: 'https://harvestmath.com/calculators/hardiness-zone-finder/',
    },
  ],
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: authorName,
  url: new URL(authorUrl, Astro.site).href,
  jobTitle: 'Editor',
  worksFor: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Hardiness Zone Finder',
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  url: new URL('/calculators/hardiness-zone-finder/', Astro.site).href,
  description: calculator.metaDescription,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: authorName,
    url: new URL(authorUrl, Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};
---

<CalculatorLayout calculator={calculator} cluster={cluster} intro={intro} lastUpdated={lastUpdated} authorName={authorName} authorUrl={authorUrl} shareImage={shareImage}>
  <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(softwareAppJsonLd)} slot="head" />

  <!-- Desktop sticky TOC in the right sidebar column -->
  <TableOfContents items={tocItems} variant="sidebar" slot="sidebar" />

  <!-- Calculator tool — immediately after intro, visible without scrolling -->
  <HardinessZoneFinder client:load />

  <p class="mt-3 text-sm text-bark-500">
    Already know your zone? Use our <a href="/calculators/frost-date-calculator/" class="text-moss-700 underline underline-offset-2 hover:text-moss-900">Frost Date Calculator</a> for your actual planting timeline &mdash; that's a different, more specific question than the zone lookup above.
  </p>

  <!-- Mobile TOC accordion — below the calculator, collapsed by default, hidden on desktop -->
  <TableOfContents items={tocItems} variant="accordion" />

  <article class="prose prose-bark mt-8 max-w-none prose-headings:font-display prose-headings:text-bark-900 prose-h2:mt-12 prose-h2:scroll-mt-24 prose-h2:text-2xl prose-h2:font-semibold prose-h3:text-lg prose-h3:font-semibold prose-a:text-moss-700 prose-strong:text-bark-900">

    <h2 id="how-to-use-this-calculator">How to Use This Calculator</h2>
    <ol>
      <li>Enter your 5-digit US ZIP code.</li>
      <li>Read your estimated USDA Plant Hardiness Zone.</li>
      <li>Check the average annual minimum winter temperature range that zone represents.</li>
    </ol>

    <h2 id="what-is-a-usda-hardiness-zone">What Is a USDA Hardiness Zone?</h2>
    <p>
      A USDA hardiness zone is a rating of how cold winter typically gets in a given area, based on <strong>average annual minimum winter temperature</strong> &mdash; nothing else. It's the standard reference behind every "hardy to zone 5" or "hardy to zone 8" label on a plant tag or seed catalog, telling you whether a perennial, shrub, or tree can be expected to survive winter outdoors in your area without special protection. A hardiness zone lookup like the one above simply automates matching your location to that number, instead of you having to cross-reference a printed map by hand.
    </p>
    <figure class="my-6 float-right ml-6 w-48 sm:w-64">
      <img
        src="/hardiness-zone-finder-zone-gradient.svg"
        alt="A gradient bar showing USDA hardiness zones from colder to warmer, with an example zone marked"
        width="400"
        height="250"
        loading="lazy"
        class="rounded-xl border border-moss-100 bg-moss-50/30"
      />
      <figcaption class="mt-2 text-xs text-bark-500">
        Each zone is a 10&deg;F band of average annual minimum winter temperature, split into two 5&deg;F half-zones.
      </figcaption>
    </figure>
    <p>
      What a hardiness zone is <em>not</em> is a general climate summary. It says nothing about summer heat, rainfall, humidity, or overall growing conditions &mdash; two places in the same zone can have very different summers. It's specifically and only a winter-cold rating, which is exactly why it's useful for one job (will this perennial survive winter here) and not the job of telling you your whole growing season.
    </p>

    <h2 id="zone-reference-table">Zone Reference Table</h2>
    <p>
      Each USDA hardiness zone represents a 10&deg;F band of average annual minimum winter temperature, split into two 5&deg;F half-zones ("a" is the colder half, "b" the warmer half of the same zone number).
    </p>
    <table>
      <thead>
        <tr>
          <th>Zone</th>
          <th>Avg. Annual Minimum (&deg;F)</th>
          <th>Avg. Annual Minimum (&deg;C)</th>
        </tr>
      </thead>
      <tbody>
        {zoneTableRows.map((z) => {
          const band = ZONE_TEMP_BANDS[z];
          return (
            <tr>
              <td>Zone {z}</td>
              <td>{formatTempRangeF(band)}</td>
              <td>{formatTempRangeC(band)}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
    <p>
      The calculator above covers the full range published on the official map (zones 1&ndash;13); the table shows zones 3&ndash;11, which covers the large majority of the continental United States.
    </p>

    <h2 id="worked-example">Worked Example</h2>
    <p>
      Say you enter ZIP code <strong>60601</strong> (Chicago, IL). The calculator matches it to <strong>Zone 6b</strong>, which represents an average annual minimum winter temperature of <strong>-5&deg;F to 0&deg;F</strong> (about -21&deg;C to -18&deg;C). That number is what a "hardy to zone 6" plant tag is rated against &mdash; a shrub or perennial labeled hardy to zone 6 should survive a typical winter low in that -5&deg;F to 0&deg;F range without dying back to the ground or needing extra winter protection. A plant rated only to zone 7 or 8, on the other hand, is a real risk in a zone 6b winter and would need siting against a protected wall, mulching, or treating as an annual.
    </p>

    <h2 id="why-your-zone-matters">Why Your Zone Matters</h2>
    <p>
      The most direct use of your zone is at the nursery or when ordering online: a plant tag rated "hardy to zone 7" is telling you it should survive winter outdoors in zones 7 and warmer, and is a gamble &mdash; or an annual, replaced every year &mdash; in anything colder. Checking your zone against that rating before buying a perennial, shrub, or tree is the single most practical use of this number.
    </p>
    <p>
      It's worth being precise about what zone does and doesn't predict. Hardiness zone tells you about <strong>winter minimum temperature survival</strong> for perennials that stay in the ground year-round. It does not tell you your frost dates &mdash; the specific spring and fall dates when frost risk starts and ends, which matter for timing annual vegetables and flowers. Those are a related but genuinely different question. Already know your zone and want your actual planting timeline instead? Use our <a href="/calculators/frost-date-calculator/">Frost Date Calculator</a> for that.
    </p>

    <h2 id="common-mistakes">Common Mistakes</h2>
    <ul>
      <li><strong>Confusing hardiness zone with frost date or planting timing.</strong> Zone tells you whether a perennial survives winter where you live; it doesn't tell you when to start seeds or when it's safe to transplant. Use the Frost Date Calculator for timing questions, and your zone for plant-buying decisions.</li>
      <li><strong>Assuming zone alone determines what will grow.</strong> Zone only measures winter cold. Summer heat, humidity, soil type, and microclimates (a sheltered wall, a low frost pocket, an exposed hilltop) all affect what actually thrives in a given spot, even within the same zone.</li>
      <li><strong>Using an outdated zone map.</strong> The USDA updated zone boundaries in its most recent map revision, shifting many areas by a half-zone or more as long-term averages changed. A zone reference from an old book, plant tag, or bookmarked page may no longer match the current official map for your area &mdash; when in doubt, check the current map directly.</li>
    </ul>

    <LeadMagnetForm
      client:load
      listId={leadMagnet.listId}
      tag={leadMagnet.tag}
      clusterName={leadMagnet.clusterName}
      icon={leadMagnet.icon}
      description={`A one-page PDF of the ${cluster.name.toLowerCase()} math from this site, emailed once.`}
    />

    <FAQBlock id="hardiness-zone-finder-faq" heading="Hardiness Zone Finder FAQ" faqs={faqs} />

    <h2 id="sources-and-further-reading">Sources &amp; further reading</h2>
    <p>
      Zone boundaries and temperature bands are checked against the official <a href="https://planthardiness.ars.usda.gov/" rel="noopener">USDA Plant Hardiness Zone Map</a>, published by the USDA Agricultural Research Service. For more on how we build and verify the formulas and reference data behind every calculator on this site, see our <a href="/methodology/">methodology page</a>.
    </p>

    <RelatedCalculatorsList id="related-calculators" items={[
      { name: 'Frost Date Calculator', url: '/calculators/frost-date-calculator/', note: 'once you know your zone, get your actual planting timeline — last frost, first frost, and a full seed-to-harvest schedule.' },
      { name: 'Seed Starting Calendar', url: '/calculators/seed-starting-calculator/', note: 'turns your frost dates into exact per-crop indoor-start and transplant dates.' },
      { name: 'Spacing & Planting cluster', url: '/clusters/spacing-and-planting/', anchorText: 'see our full vegetable garden planning timeline', note: 'zone, frost dates, seed starting, spacing, and yield, all in one place.' },
    ]} />

    <p class="mt-12 text-sm text-bark-500">
      Last updated: {formattedDate}.
    </p>
  </article>
</CalculatorLayout>
