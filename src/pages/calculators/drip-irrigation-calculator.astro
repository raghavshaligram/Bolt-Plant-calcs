import DripIrrigationCalculator from '../../components/calculators/DripIrrigationCalculator.tsx';
import TableOfContents from '../../components/TableOfContents.astro';
import LeadMagnet from '../../components/LeadMagnet.astro';
import FAQBlock from '../../components/FAQBlock.astro';
import RelatedCalculatorsList from '../../components/RelatedCalculatorsList.astro';
import { getCalculator, getCluster } from '../../data/calculators';

const calculator = getCalculator('drip-irrigation-calculator')!;
const cluster = getCluster(calculator.cluster)!;

const lastUpdated = '2026-07-09';
const formattedDate = new Date(lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const authorName = 'HarvestMath Editors';
const authorUrl = '/about/';

const intro =
  'This drip irrigation calculator works out your run time and total water delivered from your emitter count and flow rate — enter what you have, pick a target amount per plant or over an area, and get a straight answer in minutes. Built for home garden drip systems, not large-scale agricultural or professional hydraulic design.';

const tocItems = [
  { id: 'how-do-you-calculate-drip-irrigation-run-time', label: 'How It Works', icon: 'leaf' as const },
  { id: 'common-emitter-flow-rates-reference', label: 'Flow Rates Reference', icon: 'table' as const },
  { id: 'worked-example', label: 'Worked Example', icon: 'table' as const },
  { id: 'common-mistakes', label: 'Common Mistakes', icon: 'warning' as const },
  { id: 'drip-irrigation-calculator-faq', label: 'FAQ', icon: 'question' as const },
  { id: 'related-calculators', label: 'Related Calculators', icon: 'grid' as const },
];

const shareImage = new URL('/drip-irrigation-calculator-emitters.svg', Astro.site).href;

const faqs = [
  {
    q: 'How do I calculate drip irrigation run time?',
    a: 'Divide the water you want delivered by your total flow rate. For a single plant on one emitter, run time = target gallons ÷ emitter GPH. For a zone covering an area, run time = total gallons needed ÷ (number of emitters × flow rate per emitter). The calculator above does this automatically for either case.',
  },
  {
    q: 'What emitter flow rate should I use?',
    a: '1 GPH is the standard default for most vegetables, perennials, and small shrubs. Use 0.5 GPH for closely spaced small plants in heavier, slower-draining soil, and 2–4 GPH for larger shrubs, young trees, or fast-draining sandy soil that needs more volume, faster.',
  },
  {
    q: 'How many gallons does 1 inch of water over an area equal?',
    a: 'About 0.623 gallons per square foot per inch of depth — so 1 inch of water over a 50 sq ft bed is roughly 31 gallons. The calculator’s Area Coverage mode uses this exact conversion to translate a target watering depth into gallons and, from there, into run time.',
  },
  {
    q: 'How long should I run my drip irrigation system?',
    a: 'It depends entirely on your emitter flow rate and target water amount — there’s no universal number of minutes that works for every setup. Enter your emitter count, flow rate, and target amount into the calculator above for a run time matched to your actual system, not a generic rule of thumb.',
  },
  {
    q: 'Does this calculator handle system design for larger properties?',
    a: 'No — this tool is scoped to homeowner-level drip systems: figuring out run time and water delivered for a zone you already have. It does not size main lines, calculate pressure loss over distance, or plan laterals for acreage — that’s professional irrigation design territory, outside what this calculator covers.',
  },
];

// FAQBlock component handles FAQPage schema injection automatically.

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Calculate your drip irrigation run time and water delivered',
  description:
    'Use the drip irrigation calculator to find your run time and total water delivered based on your emitter count, emitter flow rate, and target water amount per plant or over an area.',
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Enter your emitter count and flow rate',
      text: 'Enter how many emitters are running on the line, then pick a standard flow rate (0.5, 1, 2, or 4 GPH) or enter a custom rate.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Choose Per Plant or Area Coverage',
      text: 'Enter a target water amount per plant, or an area and target depth of water, depending on how your system is laid out.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Read your run time and water delivered',
      text: 'The calculator shows run time in minutes or hours, total water delivered this session, and an optional weekly total.',
    },
  ],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://harvestmath.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Watering & Irrigation',
      item: 'https://harvestmath.com/clusters/watering-and-irrigation/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Drip Irrigation Calculator',
      item: 'https://harvestmath.com/calculators/drip-irrigation-calculator/',
    },
  ],
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: authorName,
  url: new URL(authorUrl, Astro.site).href,
  jobTitle: 'Editor',
  worksFor: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Drip Irrigation Calculator',
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  url: new URL('/calculators/drip-irrigation-calculator/', Astro.site).href,
  description: calculator.metaDescription,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: authorName,
    url: new URL(authorUrl, Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
