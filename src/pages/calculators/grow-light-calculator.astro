---
import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import GrowLightCalculator from '../../components/calculators/GrowLightCalculator.tsx';
import TableOfContents from '../../components/TableOfContents.astro';
import LeadMagnetForm from '../../components/LeadMagnetForm.jsx';
import FAQBlock from '../../components/FAQBlock.astro';
import RelatedCalculatorsList from '../../components/RelatedCalculatorsList.astro';
import { getCalculator, getCluster, leadMagnetConfig } from '../../data/calculators';

const calculator = getCalculator('grow-light-calculator')!;
const cluster = getCluster(calculator.cluster)!;
const leadMagnet = leadMagnetConfig[cluster.slug]!;

const lastUpdated = '2026-07-10';
const formattedDate = new Date(lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const authorName = 'HarvestMath Editors';
const authorUrl = '/about/';

const intro =
  'This DLI calculator (daily light integral) also covers grow light wattage, coverage, and hanging distance — three practical modes for houseplants, seedlings, herbs, and vegetables grown under artificial light. Pick a mode, enter what you have, and get a straight answer instead of a rule of thumb.';

const tocItems = [
  { id: 'how-do-you-calculate-grow-light-needs', label: 'How It Works', icon: 'leaf' as const },
  { id: 'target-dli-by-plant-type', label: 'Target DLI Reference', icon: 'table' as const },
  { id: 'worked-example-dli-calculation', label: 'Worked Example', icon: 'table' as const },
  { id: 'common-mistakes', label: 'Common Mistakes', icon: 'warning' as const },
  { id: 'grow-light-calculator-faq', label: 'FAQ', icon: 'question' as const },
  { id: 'related-calculators', label: 'Related Calculators', icon: 'grid' as const },
];

const shareImage = new URL('/grow-light-calculator-dli.svg', Astro.site).href;

const faqs = [
  {
    q: 'What is DLI (daily light integral)?',
    a: 'DLI is the total amount of plant-usable light a spot receives over a full day, measured in mol/m²/day. It combines light intensity (PPFD) and how many hours the light runs, giving a single number that correlates well with plant growth — much more useful than a single instantaneous reading.',
  },
  {
    q: 'How do I calculate DLI from a PPFD reading?',
    a: 'Multiply your PPFD reading (µmol/m²/s) by 3,600, multiply by your photoperiod in hours, then divide by 1,000,000. The calculator above does this instantly — enter a PPFD reading and photoperiod and it returns DLI in mol/m²/day.',
  },
  {
    q: 'What wattage grow light do I need for my growing area?',
    a: 'It depends on plant light need: roughly 15–20 actual watts per square foot for seedlings and low-light houseplants, 25–35 for leafy greens and herbs, and 40–50 for fruiting vegetables. Enter your area and light need tier into the calculator above for a specific wattage range and estimated electricity cost.',
  },
  {
    q: 'How far should a grow light be from my plants?',
    a: 'It depends on light type and growth stage. LED lights are typically hung 18–24 inches above seedlings and 12–18 inches above mature plants; fluorescent fixtures run cooler and can generally sit 6–12 inches away at either stage. Check your specific fixture’s spec sheet too, since intensity varies by model.',
  },
  {
    q: 'What is the difference between lumens and PPFD or DLI?',
    a: 'Lumens measure how bright a light looks to human eyes, weighted toward the green-yellow wavelengths we see best. PPFD and DLI measure the actual quantity of light plants can use for photosynthesis across a wider range of wavelengths. A light can have an impressive lumen rating and still be a poor grow light — lumens are not a reliable way to shop for or evaluate a grow light.',
  },
];

// FAQBlock component handles FAQPage schema injection automatically.

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Calculate DLI, grow light wattage, and hanging distance',
  description:
    'Use the grow light calculator to find your Daily Light Integral (DLI) from a PPFD reading, a recommended wattage and electricity cost for your growing area, or a recommended hanging distance for your light and growth stage.',
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Choose a mode',
      text: 'Choose a mode: Coverage & Wattage, DLI Calculator, or Light Distance.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Enter your inputs',
      text: 'Enter the inputs for that mode — growing area and light need, a PPFD reading and photoperiod, or light type and growth stage.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Read your result',
      text: 'Read your recommended wattage, DLI, or hanging distance.',
    },
  ],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://harvestmath.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Indoor Plants',
      item: 'https://harvestmath.com/clusters/indoor-plants/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Grow Light Calculator',
      item: 'https://harvestmath.com/calculators/grow-light-calculator/',
    },
  ],
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: authorName,
  url: new URL(authorUrl, Astro.site).href,
  jobTitle: 'Editor',
  worksFor: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'DLI & Grow Light Calculator',
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  url: new URL('/calculators/grow-light-calculator/', Astro.site).href,
  description: calculator.metaDescription,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: authorName,
    url: new URL(authorUrl, Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};
---

<CalculatorLayout calculator={calculator} cluster={cluster} intro={intro} lastUpdated={lastUpdated} authorName={authorName} authorUrl={authorUrl} shareImage={shareImage}>
  <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(softwareAppJsonLd)} slot="head" />

  <!-- Desktop sticky TOC in the right sidebar column -->
  <TableOfContents items={tocItems} variant="sidebar" slot="sidebar" />

  <!-- Calculator tool — immediately after intro, visible without scrolling -->
  <GrowLightCalculator client:load />

  <p class="mt-3 text-sm text-bark-500">
    See our <a href="/clusters/indoor-plants/" class="text-moss-700 underline underline-offset-2 hover:text-moss-900">complete guide to houseplant light and pot size</a> — pairs well with our <a href="/calculators/pot-size-calculator/" class="text-moss-700 underline underline-offset-2 hover:text-moss-900">Pot Size Calculator</a> for sizing up your growing setup.
  </p>

  <!-- Mobile TOC accordion — below the calculator, collapsed by default, hidden on desktop -->
  <TableOfContents items={tocItems} variant="accordion" />

  <LeadMagnetForm
    client:load
    listId={leadMagnet.listId}
    tag={leadMagnet.tag}
    clusterName={leadMagnet.clusterName}
    icon={leadMagnet.icon}
    description={`A one-page PDF of the ${cluster.name.toLowerCase()} math from this site, emailed once.`}
  />

  <article class="prose prose-bark mt-8 max-w-none prose-headings:font-display prose-headings:text-bark-900 prose-h2:mt-12 prose-h2:scroll-mt-24 prose-h2:text-2xl prose-h2:font-semibold prose-h3:text-lg prose-h3:font-semibold prose-a:text-moss-700 prose-strong:text-bark-900">

    <h2 id="how-to-use-this-calculator">How to Use This Calculator</h2>
    <ol>
      <li>Choose a mode: Coverage &amp; Wattage, DLI Calculator, or Light Distance.</li>
      <li>Enter the inputs for that mode &mdash; growing area and light need, a PPFD reading and photoperiod, or light type and growth stage.</li>
      <li>Read your recommended wattage, DLI, or hanging distance.</li>
    </ol>

    <h2 id="how-do-you-calculate-grow-light-needs">How Do You Calculate Grow Light Needs?</h2>
    <p>
      Two measurements matter for growing under artificial light: <strong>PPFD</strong> (photosynthetic photon flux density), the intensity of plant-usable light hitting a surface at a given instant, and <strong>DLI</strong> (daily light integral), the total amount of that light delivered over a full day. PPFD is measured in µmol/m&sup2;/s with a light meter; DLI is calculated from PPFD and photoperiod, and is measured in mol/m&sup2;/day.
    </p>
    <p>
      A related term worth distinguishing: <strong>PPF</strong> (photosynthetic photon flux) is the <em>total</em> light a fixture emits in all directions, measured at the source. <strong>PPFD</strong> is what actually reaches the plant canopy at a specific distance and position &mdash; always less than PPF, because light spreads and some of it misses the target area entirely. Fixture spec sheets sometimes list PPF; your light meter measures PPFD. The difference matters most for the Light Distance mode on this calculator: moving a light closer increases the PPFD at the canopy even though the fixture&rsquo;s PPF stays constant.
    </p>
    <figure class="my-6 float-right ml-6 w-48 sm:w-64">
      <img
        src="/grow-light-calculator-dli.svg"
        alt="An LED grow light hanging over a shelf of houseplants, herbs, seedlings, and a fruiting vegetable plant"
        width="400"
        height="250"
        loading="lazy"
        class="rounded-xl border border-moss-100 bg-moss-50/30"
      />
      <figcaption class="mt-2 text-xs text-bark-500">
        Light needs vary a lot by plant type and growth stage &mdash; there&rsquo;s no single right wattage or distance.
      </figcaption>
    </figure>
    <p>
      Light needs vary widely by plant type and growth stage. A low-light houseplant and a fruiting vegetable can need three to five times as much daily light to grow well &mdash; using the same setup for both is a common reason one thrives and the other stalls. Growth stage matters too: seedlings are more sensitive to intense, close-range light than mature plants, which is why recommended hanging distances shift as a plant grows.
    </p>
    <p>
      This calculator handles three related but distinct questions: how much <strong>wattage</strong> to size for a given growing area, what <strong>DLI</strong> a light meter reading works out to, and how far to <strong>hang</strong> a light for a given fixture type and growth stage. All three use the same underlying light concepts, just applied to different practical decisions.
    </p>

    <h2 id="target-dli-by-plant-type">Target DLI by Plant Type</h2>
    <p>
      These are typical target ranges, not fixed requirements &mdash; actual needs shift with temperature, CO&sup2;, and the specific species. Use them as a starting point, then adjust based on how your plants actually respond.
    </p>
    <table>
      <thead>
        <tr>
          <th>Plant type</th>
          <th>Target DLI (mol/m&sup2;/day)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Seedlings &amp; cuttings</td><td>6&ndash;8</td></tr>
        <tr><td>Low-light houseplants</td><td>6&ndash;10</td></tr>
        <tr><td>Leafy greens &amp; herbs</td><td>12&ndash;20</td></tr>
        <tr><td>Fruiting vegetables</td><td>20&ndash;30</td></tr>
      </tbody>
    </table>
    <p>
      Fruiting crops need roughly double to triple the daily light of leafy greens and houseplants &mdash; producing fruit is a much more energy-intensive process for a plant than maintaining leaves alone. The DLI Calculator mode above can compare your calculated DLI directly against any of these four target ranges.
    </p>

    <h2 id="worked-example-dli-calculation">Worked Example: DLI Calculation</h2>
    <p>
      Say a light meter reads <strong>400 &micro;mol/m&sup2;/s (PPFD)</strong> at plant canopy height, and the light runs <strong>14 hours a day</strong>.
    </p>
    <ol>
      <li><strong>Multiply PPFD by 3,600</strong> (seconds per hour): 400 &times; 3,600 = 1,440,000.</li>
      <li><strong>Multiply by photoperiod:</strong> 1,440,000 &times; 14 = 20,160,000.</li>
      <li><strong>Divide by 1,000,000</strong> to convert µmol to mol: 20,160,000 &divide; 1,000,000 = <strong>20.16 mol/m&sup2;/day</strong>.</li>
    </ol>
    <p>
      A DLI of roughly 20 comfortably covers leafy greens and herbs (target 12&ndash;20) and sits right at the entry point for fruiting vegetables (target 20&ndash;30) &mdash; workable for tomatoes or peppers, though pushing the photoperiod or PPFD higher would give more margin for a heavy-fruiting crop. The calculator above runs this same formula instantly for any PPFD reading and photoperiod.
    </p>

    <h2 id="common-mistakes">Common Mistakes</h2>
    <ul>
      <li><strong>Confusing lumens with PPFD or DLI.</strong> Lumens measure how bright a light looks to the human eye; PPFD and DLI measure the light plants can actually use for photosynthesis. A high lumen rating doesn&rsquo;t guarantee a good grow light &mdash; check PPFD or DLI specs instead.</li>
      <li><strong>Hanging lights too close or too far.</strong> Too close can stress or bleach leaves with excess intensity and uneven coverage; too far under-delivers light and wastes the fixture&rsquo;s potential. Use the Light Distance mode above as a starting point, then watch how the plant responds.</li>
      <li><strong>Ignoring photoperiod.</strong> The same fixture at the same distance delivers very different DLI depending on how many hours a day it runs &mdash; a bright light for 8 hours can under-deliver compared to a dimmer light for 16.</li>
      <li><strong>Using the wrong DLI target for the plant type.</strong> A DLI that&rsquo;s perfect for a low-light houseplant will leave a fruiting tomato under-lit and unproductive. Match the target range to what you&rsquo;re actually growing, not a generic number.</li>
    </ul>

    <FAQBlock id="grow-light-calculator-faq" heading="Grow Light Calculator FAQ" faqs={faqs} />

    <h2 id="sources-and-further-reading">Sources &amp; further reading</h2>
    <p>
      Target DLI ranges draw on <a href="https://www.pubs.ext.vt.edu/SPES/spes-720/spes-720.html" rel="noopener">Virginia Cooperative Extension&rsquo;s guide to calculating and using Daily Light Integral</a> and DLI guidance published by Michigan State University Extension&rsquo;s floriculture program. Wattage and hanging-distance ranges reflect typical home-grower LED and fluorescent fixture guidance rather than a single study. For more on how we build and verify the formulas behind every calculator on this site, see our <a href="/methodology/">methodology page</a>.
    </p>

    <RelatedCalculatorsList id="related-calculators" items={[
      { name: 'Indoor Plants cluster', url: '/clusters/indoor-plants/', anchorText: 'see our complete guide to houseplant light and pot size', note: 'light categories, repotting signals, and a quick-reference table by common houseplant.' },
      { name: 'Pot Size Calculator', url: '/calculators/pot-size-calculator/', note: 'sizing up a growing setup? Figure out the right pot size to go with your lighting.' },
    ]} />

    <p class="mt-12 text-sm text-bark-500">
      Last updated: {formattedDate}.
    </p>
  </article>
</CalculatorLayout>
