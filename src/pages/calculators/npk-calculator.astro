  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Choose a calculation mode',
      text: 'Select Granular for a dry fertilizer application rate, Liquid for a dissolved feed solution, or Blend to combine multiple fertilizers toward a target ratio.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Enter your fertilizer’s N-P-K percentages',
      text: 'Type the three numbers from the fertilizer label (e.g. 10-10-10) into the N%, P%, and K% fields for each product.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Enter your target rate, strength, or ratio',
      text: 'Depending on the mode, enter a target lb-N-per-1,000-sq-ft rate and area, a target PPM or dilution ratio and container size, or a target N-P-K ratio, rate, and area.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Read the result',
      text: 'The calculator shows the exact amount of fertilizer product needed, updating live as you type. Blend mode also flags when an exact target ratio isn’t mathematically achievable with the chosen products.',
