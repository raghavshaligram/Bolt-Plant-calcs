const calculator = getCalculator('topsoil-calculator')!;
const cluster = getCluster(calculator.cluster)!;

const lastUpdated = '2026-07-07';
const formattedDate = new Date(lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const authorName = 'HarvestMath Editors';
const authorUrl = '/about/';

const intro =
  'Figure out exactly how much topsoil you need for any raised bed, new lawn, or leveling job. Enter your area and desired depth, and the tool converts it into cubic feet, cubic yards, and an estimated weight in tons — the units suppliers actually quote in. Built for gardeners, landscapers, and anyone trying to order the right truckload without paying for too much (or coming up short).';

const tocItems = [
  { id: 'how-much-topsoil-do-i-need', label: 'How Much Topsoil Do I Need', icon: 'leaf' as const },
  { id: 'worked-example', label: 'Worked Example', icon: 'table' as const },
  { id: 'common-mistakes', label: 'Common Mistakes', icon: 'warning' as const },
  { id: 'topsoil-calculator-faq', label: 'FAQ', icon: 'question' as const },
  { id: 'related-calculators', label: 'Related Calculators', icon: 'grid' as const },
];

const shareImage = new URL('/topsoil-calculator-raised-bed-fill.svg', Astro.site).href;

const faqs = [
  {
    q: 'How do I calculate how much topsoil I need?',
    a: 'Measure your area in square feet (length \u00d7 width), multiply by your depth in inches divided by 12 to get cubic feet, then divide by 27 for cubic yards. The calculator above does this live as you type and also gives you an estimated weight in tons.',
  },
  {
    q: 'How much topsoil do I need?',
    a: 'It depends on the depth. A 4\u00d78 raised bed at 10 inches deep needs about 26.7 cubic feet (roughly 1 cubic yard). A 1,000 sq ft lawn topdressed at 0.25 inches needs about 2.1 cubic feet \u2014 less than a single bag. Use the toggle above to switch between \u201cfill a bed\u201d and \u201ctopdress a lawn\u201d to get the right default depth.',
  },
  {
    q: 'How do you calculate topsoil coverage?',
    a: 'Coverage is area \u00d7 depth. One cubic yard of topsoil (27 cubic feet) covers 324 square feet at 1 inch deep, 162 sq ft at 2 inches, 108 sq ft at 3 inches, and 81 sq ft at 4 inches. The calculator handles this for you in real time as you change the depth.',
  },
  {
    q: 'Should I buy topsoil in bulk or in bags?',
    a: 'Bulk (sold by the cubic yard, delivered by truck) almost always wins past about 2 cubic yards. Below that, bagged topsoil (typically 1\u20131.5 cu ft bags) is easier to transport and not much more expensive. For a full raised bed that needs 3+ yards, get a bulk quote \u2014 you\u2019ll save on both the material and the bag-hauling.',
  },
  {
    q: 'Can I use this to level or topdress my lawn?',
    a: 'Yes. Switch the toggle above to \u201cTopdress a lawn\u201d and the calculator sets a default depth of 0.25\u20130.5 inches, which is the right range for a thin topdressing layer. Enter your lawn area and adjust the depth if you\u2019re filling deeper low spots. Keep it under 0.5 inches per application so the grass can breathe and grow through.',
  },
  {
    q: 'How many bags of topsoil are in a yard?',
    a: 'One cubic yard is 27 cubic feet. A standard 40 lb bag of topsoil holds about 0.75 cubic feet, so you need approximately 36 bags per cubic yard. Bag sizes vary \u2014 some are sold as 1 cu ft or 1.5 cu ft bags. Check the label and divide 27 by the bag volume to get an exact count for whatever product you\u2019re buying. Past about 2 yards, bulk delivery almost always costs less than buying bags.',
  },
  {
    q: 'How many wheelbarrows is a yard of topsoil?',
    a: 'Plan on 8\u20139 wheelbarrow loads per cubic yard with a standard contractor wheelbarrow (3\u20133.5 cu ft capacity). Smaller garden wheelbarrows hold 2\u20132.5 cu ft, putting you closer to 11\u201314 loads per yard. Knowing this helps you plan your time and decide whether it\u2019s worth paying for dump-and-spread delivery instead of unloading by hand.',
  },
];

// FAQBlock component handles FAQPage schema injection automatically.

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Calculate how much topsoil you need',
  description:
    'Use the topsoil calculator to figure out how many cubic feet, cubic yards, or tons of topsoil to buy for raised beds, new lawns, and leveling jobs.',
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Choose your project type',
      text: 'Toggle between \u201cFill a bed\u201d (8\u201312 inch default depth) and \u201cTopdress a lawn\u201d (0.25\u20130.5 inch default depth) to start with a sensible default.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Enter your area',
      text: 'Type the length and width of your bed or lawn in feet, or switch to total square feet if you already know the area.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Set the desired depth',
      text: 'Adjust the depth in inches. The calculator updates cubic feet, cubic yards, and estimated tons live as you type.',
    },
  ],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://harvestmath.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Soil & Amendments',
      item: 'https://harvestmath.com/clusters/soil-and-amendments/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Topsoil Calculator',
      item: 'https://harvestmath.com/calculators/topsoil-calculator/',
    },
  ],
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: authorName,
  url: new URL(authorUrl, Astro.site).href,
  jobTitle: 'Editor',
  worksFor: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Topsoil Calculator',
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  url: new URL('/calculators/topsoil-calculator/', Astro.site).href,
  description: calculator.metaDescription,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: authorName,
    url: new URL(authorUrl, Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};
---

<CalculatorLayout calculator={calculator} cluster={cluster} intro={intro} lastUpdated={lastUpdated} authorName={authorName} authorUrl={authorUrl} shareImage={shareImage}>
  <script type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(softwareAppJsonLd)} slot="head" />

  <!-- Desktop sticky TOC in the right sidebar column -->
  <TableOfContents items={tocItems} variant="sidebar" slot="sidebar" />

  <!-- Left column content: calculator → mobile TOC → lead magnet → article -->
  <!-- Calculator tool — immediately after intro, visible without scrolling -->
  <TopsoilCalculator client:load />

  <p class="mt-3 text-sm text-bark-500">
    For pots and containers, use our <a href="/calculators/soil-volume-calculator/" class="text-moss-700 underline underline-offset-2 hover:text-moss-900">Soil Volume Calculator</a> instead.
  </p>

  <!-- Mobile TOC accordion — below the calculator, collapsed by default, hidden on desktop -->
  <TableOfContents items={tocItems} variant="accordion" />

  <LeadMagnet variant="full" />

  <article class="prose prose-bark mt-8 max-w-none prose-headings:font-display prose-headings:text-bark-900 prose-h2:mt-12 prose-h2:scroll-mt-24 prose-h2:text-2xl prose-h2:font-semibold prose-h3:text-lg prose-h3:font-semibold prose-a:text-moss-700 prose-strong:text-bark-900">
    <h2 id="how-much-topsoil-do-i-need">How Much Topsoil Do I Need?</h2>
    <p>
      The right amount of topsoil depends entirely on <strong>what you&rsquo;re doing with it</strong>. A raised bed needs to be filled almost to the rim &mdash; usually 8 to 12 inches deep. A lawn topdressing is a thin dusting, a quarter to half an inch, just enough to level low spots and work organic matter into the surface. These are wildly different volumes, and mixing them up is the most common reason people order the wrong amount.
    </p>
    <p>
      Quick reference: <strong>1 cubic yard covers about 324 sq ft at 1 inch deep, or 108 sq ft at 3 inches deep</strong>. Coverage drops fast as depth increases, which is why getting the depth right before you order matters more than getting the area exactly right.
    </p>
    <p>
      One distinction worth making before you order: topsoil is not the same thing as <strong>fill dirt</strong>. Fill dirt is typically subsoil or excavation spoil dug from well below the surface &mdash; largely sterile mineral material with little to no organic matter or biological activity, sold cheap because its only job is occupying volume. Topsoil, even unscreened, comes from the biologically active surface layer and retains some organic matter that supports plant growth. If a listing doesn&rsquo;t specify which one you&rsquo;re getting, ask &mdash; fill dirt is fine for a low spot nobody will plant in, but a poor substitute anywhere roots need to grow.
    </p>
    <figure class="my-6 float-right ml-6 w-48 sm:w-64">
      <img
        src="/topsoil-calculator-raised-bed-fill.svg"
        alt="Topsoil being added to a raised garden bed, for calculating fill volume."
        width="400"
        height="250"
        loading="lazy"
        class="rounded-xl border border-moss-100 bg-moss-50/30"
      />
      <figcaption class="mt-2 text-xs text-bark-500">
        Topsoil being added to a raised bed — measure depth before you order, not after.
      </figcaption>
    </figure>
    <p>
      The calculator above has a toggle for exactly this: <strong>&ldquo;Fill a bed&rdquo;</strong> sets a default depth of 10 inches, and <strong>&ldquo;Topdress a lawn&rdquo;</strong> sets 0.375 inches. Adjust the depth to match your project and the result updates live. You get cubic feet, cubic yards, and an estimated weight in tons &mdash; the number your supplier will quote you for a bulk delivery.
    </p>
    <p>
      The weight estimate matters because topsoil is sold by the truckload, and trucks are weight-limited, not volume-limited. Rather than a single flat number, it&rsquo;s more honest to think of it as a range: loose or dry topsoil typically runs about <strong>1.0&ndash;1.3 tons per cubic yard</strong>, while wet or compacted topsoil can climb to <strong>1.5&ndash;1.7 tons per cubic yard</strong>. Moisture content is by far the biggest factor &mdash; a truckload pulled from a stockpile the morning after rain can weigh noticeably more than the same material bone-dry. The calculator uses 1.2 tons as a reasonable middle-of-the-range estimate and labels it clearly as approximate. If your supplier quotes by weight, ask what moisture condition their figure assumes.
    </p>

    <h2 id="worked-example">Worked Example</h2>
    <p>
      Let&rsquo;s say you have a <strong>10 &times; 10 foot raised bed</strong> and you want to fill it <strong>4 inches deep</strong> with topsoil. Here&rsquo;s the math, step by step:
    </p>
    <ol>
      <li><strong>Area:</strong> 10 ft &times; 10 ft = <strong>100 square feet</strong>.</li>
      <li><strong>Convert depth to feet:</strong> 4 inches &divide; 12 = 0.333 feet.</li>
      <li><strong>Cubic feet:</strong> 100 sq ft &times; 0.333 ft = <strong>33.3 cubic feet</strong> of topsoil.</li>
      <li><strong>Cubic yards:</strong> 33.3 &divide; 27 = <strong>1.23 cubic yards</strong> (round to 1.5 yards if you&rsquo;re buying bulk).</li>
      <li><strong>Estimated tons:</strong> 1.23 &times; 1.2 = <strong>~1.48 tons</strong> (approximate).</li>
    </ol>
    <p>
      So for a 10&times;10 bed at 4 inches deep, you need <strong>33.3 cubic feet</strong>, <strong>1.23 cubic yards</strong>, or roughly <strong>1.5 tons</strong> of topsoil. If you&rsquo;re buying bulk, round up to 1.5 yards &mdash; it&rsquo;s always better to have a little extra for settling and uneven ground than to come up short and pay a second delivery fee.
    </p>

    <LeadMagnet variant="compact" />

    <h2 id="common-mistakes">Common Mistakes</h2>
    <ul>
      <li><strong>Confusing fill depth with topdressing depth.</strong> A raised bed needs 8&ndash;12 inches. A lawn topdressing needs 0.25&ndash;0.5 inches. Using the wrong depth is the #1 reason for ordering the wrong amount. Use the toggle above to start with the right default.</li>
      <li><strong>Forgetting that topsoil settles.</strong> Loose topsoil settles 10&ndash;15% after the first rain. Round up, not down, or you&rsquo;ll be a few inches short once it compacts.</li>
      <li><strong>Assuming all topsoil weighs the same.</strong> The 1.2 tons-per-yard figure is a middle-of-the-range estimate, not a fixed number &mdash; loose or dry topsoil often runs 1.0&ndash;1.3 tons per yard, while wet or compacted topsoil can reach 1.5&ndash;1.7 tons per yard. If your supplier quotes by weight, ask what moisture condition their figure assumes.</li>
      <li><strong>Ordering exactly the calculated volume.</strong> Round up 5&ndash;10% for settling, uneven ground, and spillage on most topsoil orders. But that&rsquo;s a starting point, not a guarantee &mdash; looser or unscreened topsoil can settle noticeably more than that once it&rsquo;s watered in, so round up further if you&rsquo;re unsure what you&rsquo;re getting. A small surplus is easy to spread; a shortfall means a second delivery charge.</li>
      <li><strong>Not accounting for existing soil.</strong> If your bed already has 4 inches of soil and you want 10 inches total, you only need 6 inches of new topsoil &mdash; not 10. Measure the gap, not the bed depth.</li>
    </ul>

    <FAQBlock id="topsoil-calculator-faq" heading="Topsoil Calculator FAQ" faqs={faqs} />

    <LeadMagnet variant="compact" />

    <h2 id="sources-and-further-reading">Sources &amp; further reading</h2>
    <p>
      Topsoil depth and coverage guidance in this article draws on general recommendations from university cooperative extension services (such as your state&rsquo;s land-grant extension office) and the USDA Natural Resources Conservation Service. For more on how we source and review the formulas behind every calculator, see our <a href="/methodology/">methodology page</a>. For region-specific guidance on soil type, compaction, and drainage, search &ldquo;<a href="https://extension.org/search/?q=topsoil">topsoil</a>&rdquo; on Extension.org or your local extension office&rsquo;s website. For how topsoil compares to garden soil and where it fits in a larger project, see our <a href="/blog/topsoil-vs-garden-soil/">topsoil vs. garden soil guide</a> or our <a href="/clusters/soil-and-amendments/">complete guide to soil and amendments</a>.
    </p>

    <RelatedCalculatorsList id="related-calculators" items={[
      { name: 'Soil & Amendments cluster', url: '/clusters/soil-and-amendments/', anchorText: 'Soil & Amendments cluster', note: 'the full set of soil, mulch, and compost calculators on this site.' },
      { name: 'Mulch Calculator', url: '/calculators/mulch-calculator/', note: 'once your bed is filled with topsoil, use this to calculate how much mulch to add on top.' },
    ]} />

    <p class="mt-12 text-sm text-bark-500">
      This page was last updated on {formattedDate}. The calculator itself is unchanged &mdash; only the surrounding guidance is updated as topsoil best practices evolve.
    </p>
  </article>
</CalculatorLayout>
