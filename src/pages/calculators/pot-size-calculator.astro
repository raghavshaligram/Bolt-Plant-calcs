const tocItems = [
  { id: 'how-do-you-determine-the-right-pot-size', label: 'Finding the Right Size', icon: 'leaf' as const },
  { id: 'pot-size-conversion-chart', label: 'Conversion Chart', icon: 'table' as const },
  { id: 'container-size-guide-by-plant', label: 'Guide by Plant', icon: 'table' as const },
  { id: 'worked-example', label: 'Worked Example', icon: 'table' as const },
  { id: 'common-mistakes', label: 'Common Mistakes', icon: 'warning' as const },
  { id: 'pot-size-calculator-faq', label: 'FAQ', icon: 'question' as const },
  { id: 'related-calculators', label: 'Related Calculators', icon: 'grid' as const },
];

const shareImage = new URL('/pot-size-calculator-nesting-pots.svg', Astro.site).href;

const faqs = [
  {
    q: 'What size pot do I need for my plant?',
    a: 'It depends on the plant&rsquo;s mature size and root system, not its current size. As a rough rule: 1&ndash;3 gal for small herbs and salad greens, 4&ndash;6 gal for medium vegetables, and 8&ndash;10 gal or more for large fruiting vegetables like tomatoes and peppers &mdash; check the Container Size Guide above for houseplants and specific crops.',
  },
  {
    q: 'How do I convert pot size from inches to gallons?',
    a: 'Diameter alone doesn&rsquo;t determine volume &mdash; you also need height, since a wide, shallow pot and a narrow, tall pot of the same diameter hold very different amounts of soil. Use the calculator&rsquo;s Unit Converter mode above: pick a standard nursery size to see its real gallon and liter equivalent, or enter a custom diameter and height to calculate volume directly.',
  },
  {
    q: 'Is a &ldquo;1-gallon&rdquo; pot actually one gallon?',
    a: 'No &mdash; nursery &ldquo;gallon&rdquo; sizing is a trade convention, not a literal liquid gallon. A standard 1-gallon nursery container typically holds closer to 0.7&ndash;0.8 actual gallons, and exact dimensions vary by manufacturer with no single enforced industry standard. Treat &ldquo;gallon&rdquo; labels as a size category rather than a precise volume, and check the conversion chart above if you need the real number.',
  },
  {
    q: 'What size container do vegetables need?',
    a: 'It depends on the vegetable&rsquo;s mature size. Per University of Maryland Extension guidance, large fruiting vegetables like tomatoes, peppers, eggplant, and cucumbers need a minimum of 8&ndash;10 gallons; medium vegetables like summer squash and cole crops need 4&ndash;6 gallons; and small vegetables and herbs like lettuce, basil, and radishes do fine in 1&ndash;3 gallons.',
  },
  {
    q: 'When should I repot my plant into a larger container?',
    a: 'Repot once roots start growing out of the drainage holes, circle visibly around the inside of the root ball, or the plant dries out unusually fast between waterings. Size up by roughly 2 inches of diameter at a time rather than jumping several sizes at once &mdash; an oversized jump surrounds the roots with more soil than they can use, which is a common cause of root rot.',
  },
];

// FAQBlock component handles FAQPage schema injection automatically.

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Find the right pot size, convert units, or plan a repotting size-up',
  description:
    'Use the pot size calculator to convert container sizes between inches, gallons, and liters, find the recommended next size up when repotting, or look up the minimum container size for a plant or vegetable.',
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Choose a calculation mode',
      text: 'Select Unit Converter to convert a pot size, Repotting Size-Up to find the next container size, or Plant Guide to look up a minimum container size by plant.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Enter your pot size or select a plant',
      text: 'Depending on the mode, pick a standard nursery size or enter custom dimensions, select your current pot size, or choose a plant or vegetable from the list.',
