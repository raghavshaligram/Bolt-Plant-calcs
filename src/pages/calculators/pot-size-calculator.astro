      { name: 'NPK Calculator', url: '/calculators/npk-calculator/', note: 'once your plant is potted, dial in a liquid feeding rate for its container size.' },
    ]} />

    <p class="mt-12 text-sm text-bark-500">
      Last updated: {formattedDate}.
    </p>
  </article>
</CalculatorLayout>
