import RainBarrelCalculator from '../../components/calculators/RainBarrelCalculator.tsx';
import TableOfContents from '../../components/TableOfContents.astro';
import LeadMagnetForm from '../../components/LeadMagnetForm.jsx';
import FAQBlock from '../../components/FAQBlock.astro';
import RelatedCalculatorsList from '../../components/RelatedCalculatorsList.astro';
import { getCalculator, getCluster, leadMagnetConfig } from '../../data/calculators';

const calculator = getCalculator('rain-barrel-calculator')!;
const cluster = getCluster(calculator.cluster)!;
const leadMagnet = leadMagnetConfig[cluster.slug]!;

const lastUpdated = '2026-07-11';
const formattedDate = new Date(lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const legalLastVerified = formattedDate;

const authorName = 'HarvestMath Editors';
const authorUrl = '/about/';

const intro =
  'This rain barrel calculator covers two different numbers: how much rainwater you can actually collect from your roof, and how much water pressure you’ll get out of the barrel’s spigot. Enter your roof area and rainfall amount for the collection estimate, or the height of your barrel above the spigot for the pressure estimate — both update live, independently of each other.';

const tocItems = [
  { id: 'how-much-rainwater-can-you-collect', label: 'How Much Can You Collect?', icon: 'leaf' as const },
  { id: 'how-much-water-pressure-will-you-get', label: 'Water Pressure Explained', icon: 'table' as const },
  { id: 'is-collecting-rainwater-legal-in-your-area', label: 'Is It Legal?', icon: 'warning' as const },
  { id: 'worked-example', label: 'Worked Examples', icon: 'table' as const },
  { id: 'common-mistakes', label: 'Common Mistakes', icon: 'warning' as const },
  { id: 'rain-barrel-calculator-faq', label: 'FAQ', icon: 'question' as const },
  { id: 'related-calculators', label: 'Related Calculators', icon: 'grid' as const },
];

const shareImage = new URL('/rain-barrel-calculator-roof-collection.svg', Astro.site).href;

const faqs = [
  {
    q: 'How many liters are in a rain barrel?',
    a: 'A standard rain barrel holds 50 gallons, which is about 189 liters. Sizes vary though — smaller barrels run 30–40 gallons (114–151 L), and larger cisterns can hold several hundred gallons. Check the specific product for its exact capacity.',
  },
  {
    q: 'How much does a barrel of water weigh?',
    a: 'Water weighs about 8.34 lb per gallon, so a full 50-gallon rain barrel weighs roughly 417 lb (about 189 kg) plus the weight of the barrel itself. This is why rain barrels need a sturdy, level base — a full barrel is not something you can casually reposition.',
  },
  {
    q: 'How many inches of rain does it take to fill a 5-gallon bucket?',
    a: 'From 1 sq ft of roof, 1 inch of rain yields about 0.623 gallons, so a 5-gallon bucket needs roughly 8 sq ft of roof area per inch of rain (5 ÷ 0.623). For a full-size roof, even a fraction of an inch fills a bucket almost instantly — collection scales with roof area, not just rainfall.',
  },
  {
    q: 'How do I calculate water pressure from a rain barrel?',
    a: 'Multiply the height of the water surface above your spigot (in feet) by 0.433 to get PSI. A barrel elevated 2–3 ft on a stand gives roughly 1–1.5 PSI — enough for gravity-fed drip irrigation, well short of the 15–30 PSI a standard sprinkler needs.',
  },
];

// FAQBlock component handles FAQPage schema injection automatically.

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Calculate rainwater collection and rain barrel water pressure',
  description:
    'Use the rain barrel calculator to estimate gallons of rainwater collected from a roof, and the water pressure available from a rain barrel spigot.',
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Enter roof area and rainfall',
      text: 'Enter your roof area and rainfall amount.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Read the collection estimate',
      text: 'Read your total gallons collected and recommended barrel count.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Enter barrel height for water pressure',
      text: 'Enter your barrel height in the water pressure section.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Read the water pressure',
      text: 'Read your spigot water pressure in PSI.',
    },
  ],
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://harvestmath.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Watering & Irrigation',
      item: 'https://harvestmath.com/clusters/watering-and-irrigation/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Rain Barrel Calculator',
      item: 'https://harvestmath.com/calculators/rain-barrel-calculator/',
    },
  ],
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: authorName,
  url: new URL(authorUrl, Astro.site).href,
  jobTitle: 'Editor',
  worksFor: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
};

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Rain Barrel Calculator',
  applicationCategory: 'CalculatorApplication',
  operatingSystem: 'Web',
  url: new URL('/calculators/rain-barrel-calculator/', Astro.site).href,
  description: calculator.metaDescription,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: authorName,
    url: new URL(authorUrl, Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'HarvestMath',
  },
