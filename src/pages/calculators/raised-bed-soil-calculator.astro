  { id: 'worked-example', label: 'Worked Example', icon: 'table' as const },
  { id: 'common-mistakes', label: 'Common Mistakes', icon: 'warning' as const },
  { id: 'raised-bed-soil-calculator-faq', label: 'FAQ', icon: 'question' as const },
