  '@type': 'HowTo',
  name: 'Calculate how much soil you need for a raised bed',
  description:
    'Use the raised bed soil calculator to find cubic feet, cubic yards, bags, and estimated weight for any raised bed size.',
  totalTime: 'PT1M',
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Choose a bed size preset or enter custom dimensions',
      text: 'Click a preset button (4×4, 4×8, or 4×2) to auto-fill the length and width, or type your own dimensions directly.',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Set your fill depth',
      text: 'Enter the depth in inches you want to fill. Typical raised beds need 8–12 inches.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Choose your bag size',
      text: 'Toggle between 1.5 cu ft and 2 cu ft bag sizes to see the bag count that matches what your store sells.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Read the results',
      text: 'The calculator shows cubic feet, cubic yards, bag count, and estimated weight in pounds — updating live as you type.',
    },
  ],
