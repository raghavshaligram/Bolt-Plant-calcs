---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  /** When true, use `title` verbatim for the <title> tag instead of appending "| HarvestMath". */
  rawTitle?: boolean;
  ogImage?: string;
  /** Open Graph object type. "article" for blog posts; "website" (default) for the homepage, calculators, and cluster pages. */
  pageType?: 'website' | 'article';
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  rawTitle = false,
  ogImage = '/og-default.png',
  pageType = 'website',
  canonical,
  noindex = false,
} = Astro.props;

const siteName = 'HarvestMath';
const fullTitle = rawTitle ? title : (title.includes(siteName) ? title : `${title} | ${siteName}`);
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Analytics (GA4) — loaded site-wide from this shared layout only. -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-L7SK0FES3Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-L7SK0FES3Q');
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="HarvestMath Blog" href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={pageType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
