---
// LeadMagnet opt-in. Two variants:
// - "full":    card with heading, description, email form, privacy note
// - "compact": smaller card for placement deeper in the page
//
// Visual theme is intentionally identical to LeadMagnetForm.jsx (the
// calculator-page version of this form): same gradient card background,
// icon badge, Playfair Display heading, and color palette -- so every
// signup form on the site (calculator or blog) looks like the same
// product, not two different ones depending on which page type you're on.
//
// Props:
//   headline   — explicit override for the headline. Takes precedence over
//                the leadMagnetCopy lookup below. Only companion-planting-chart
//                currently uses this (its own dedicated PDF + list, not a
//                cluster-shared cheat sheet).
//   clusterTag — tag identifier sent as a hidden field, and used as the
//                leadMagnetCopy/leadMagnetIcon lookup key when no explicit
//                headline is given (default: "soil-cluster").
//   variant    — "full" | "compact" (default: "full")
//   listId     — Brevo list ID to actually submit the signup to. If omitted,
//                the form renders but doesn't submit anywhere (matches prior
//                behavior on articles that haven't been wired to a list yet).
import { Shovel, FlaskConical, Droplets, Ruler, Sprout, Flower2, TreeDeciduous, Thermometer } from 'lucide-react';
import { leadMagnetCopy } from '../data/leadMagnetCopy';
import { leadMagnetIcon } from '../data/leadMagnetIcon';

const iconMap: Record<string, any> = {
  Shovel,
  FlaskConical,
  Droplets,
  Ruler,
  Sprout,
  Flower2,
  TreeDeciduous,
  Thermometer,
};

export interface Props {
  variant?: 'full' | 'compact';
  /** Override the opt-in headline. Takes precedence over leadMagnetCopy. */
  headline?: string;
  /** Tag identifier sent as a hidden field, and the leadMagnetCopy/leadMagnetIcon lookup key. */
  clusterTag?: string;
  /** Brevo list ID. Omit to leave this instance unwired (no-op on submit). */
  listId?: number;
}

const {
  variant = 'full',
  headline,
  clusterTag = 'soil-cluster',
  listId,
} = Astro.props;

const resolvedHeadline = headline ?? leadMagnetCopy[clusterTag] ?? 'Get the free cheat sheet';
const Icon = iconMap[leadMagnetIcon[clusterTag]] ?? null;

// The copy reads as one flowing sentence with a bolded lead-in (e.g. "Get
// the Soil & Amendments Cheat Sheet — bag counts, mix ratios..."). Split on
// the em dash so the hook before it renders as the card's heading and the
// rest as supporting description, matching the heading+description split
// LeadMagnetForm.jsx uses on calculator pages.
const dashIndex = resolvedHeadline.indexOf('—');
const headingText = dashIndex === -1 ? resolvedHeadline : resolvedHeadline.slice(0, dashIndex).trim();
const descriptionText = dashIndex === -1 ? 'Emailed once, no follow-up spam.' : resolvedHeadline.slice(dashIndex).trim();

const inputIdSuffix = variant === 'compact' ? '-compact' : '';
const emailInputId = `lead-magnet-email${inputIdSuffix}-${clusterTag}`;
const formId = `lead-magnet-form${inputIdSuffix}-${clusterTag}`;
const successId = `lead-magnet-success${inputIdSuffix}-${clusterTag}`;
const errorId = `lead-magnet-error${inputIdSuffix}-${clusterTag}`;

const isFull = variant === 'full';
// Mobile sizing is capped explicitly (not just "desktop size minus a
// breakpoint") so the decorative graphic and heading row stay a modest
// accent on a 375px screen instead of dominating it -- the same fixed size
// used to apply uniformly from 0px all the way to the sm: breakpoint.
const cardPad = isFull ? 'p-4 sm:p-8' : 'p-4 sm:p-5';
const cardMargin = isFull ? 'my-6 sm:my-10' : 'my-6 sm:my-8';
const planterSize = isFull ? 'h-12 w-12 sm:h-24 sm:w-24' : 'h-10 w-10 sm:h-14 sm:w-14';
const iconBadgeSize = isFull ? 'h-9 w-9 sm:h-11 sm:w-11' : 'h-7 w-7 sm:h-8 sm:w-8';
const iconClass = isFull ? 'h-5 w-5 sm:h-6 sm:w-6' : 'h-4 w-4';
const headingSize = isFull ? 'text-lg sm:text-xl' : 'text-base';
---

<div class={`${cardMargin} w-full rounded-2xl bg-gradient-to-br from-[#E8A94A]/20 via-[#F5F1E8] to-[#4A7C59]/10 ${cardPad} shadow-card ring-1 ring-[#5C4433]/15`}>
  <div class="flex flex-col items-center gap-3 sm:flex-row sm:items-start sm:gap-5">
    <svg viewBox="0 0 96 112" aria-hidden="true" class={`${planterSize} shrink-0`}>
      <path d="M28 72h40l-5 28a6 6 0 0 1-6 5H39a6 6 0 0 1-6-5l-5-28Z" fill="#C2894F" />
      <path d="M24 72h48l2-8a4 4 0 0 0-4-5H26a4 4 0 0 0-4 5l2 8Z" fill="#B0723D" />
      <ellipse cx="48" cy="67" rx="18" ry="4" fill="#3D322C" opacity="0.25" />
      <path d="M48 67c0-14-2-22-2-30" stroke="#385030" stroke-width="3" stroke-linecap="round" />
      <path d="M46 40c-6-5-9-11-7-18 7 1 12 6 14 12 1 4 0 7-2 9-2 1-4 0-5-3Z" fill="#46643C" />
      <path d="M50 34c6-4 10-10 9-17-7 0-13 4-15 10-1 4 0 7 2 9 2 1 3 0 4-2Z" fill="#5D7D50" opacity="0.85" />
      <path d="M48 37c-1-6 0-11 3-15 4 3 6 8 5 13-1 3-3 5-5 5-2 0-3-1-3-3Z" fill="#7D9A70" opacity="0.7" />
    </svg>

    <div class="w-full flex-1 text-center sm:text-left">
      <div id={`${formId}-view`}>
        <div class="flex items-center justify-center gap-3 sm:justify-start">
          {Icon && (
            <span class={`flex ${iconBadgeSize} shrink-0 items-center justify-center rounded-full bg-[#E8A94A]/25 text-[#3D6647]`}>
              <Icon className={iconClass} aria-hidden="true" />
            </span>
          )}
          <h3
            class={`${headingSize} font-semibold text-[#3D6647]`}
            style="font-family: 'Playfair Display', Georgia, serif;"
          >
            {headingText}
          </h3>
        </div>
        <p class="mt-2 mb-4 text-sm leading-relaxed text-[#5C4433]">
          {descriptionText}
        </p>

        <form
          id={formId}
          aria-label={`${headingText} signup`}
        >
          <input type="hidden" name="cluster_tag" value={clusterTag} />
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start">
            <div class="flex-1">
              <label for={emailInputId} class="sr-only">Email address</label>
              <input
                id={emailInputId}
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="you@example.com"
                class="w-full rounded-md border border-[#5C4433] bg-[#F5F1E8] px-4 py-2.5 text-sm text-[#5C4433] shadow-sm transition placeholder:text-[#5C4433]/50 focus:border-[#3D6647] focus:outline-none focus:ring-2 focus:ring-[#E8A94A]"
              />
              <p id={errorId} class="mt-1.5 hidden text-sm text-red-600"></p>
            </div>
            <button
              type="submit"
              class="inline-flex shrink-0 items-center justify-center whitespace-nowrap rounded-md bg-[#3D6647] px-5 py-2.5 text-sm font-semibold text-[#F5F1E8] shadow-sm transition-colors duration-200 hover:bg-[#4A7C59] focus:outline-none focus:ring-2 focus:ring-[#E8A94A] focus:ring-offset-2 disabled:cursor-not-allowed disabled:bg-[#3D6647]/70"
            >
              Get the Cheat Sheet
            </button>
          </div>
        </form>
        <p class="mt-3 text-xs text-[#5C4433]/80">
          One email with the PDF. No newsletter list. By signing up, you agree to our{' '}
          <a href="/privacy-policy/" class="underline hover:text-[#3D6647]">Privacy Policy</a>.
        </p>
      </div>

      <div id={successId} class="hidden rounded-xl bg-[#3D6647] p-5">
        <p class="font-semibold text-[#F5F1E8]" style="font-family: 'Playfair Display', Georgia, serif;">
          Check your inbox!
        </p>
        <p class="mt-1.5 text-sm leading-relaxed text-[#F5F1E8]">
          We&rsquo;re sending it to your email now. If you don&rsquo;t see it in a minute or two, check your spam or promotions folder &mdash; and marking it &ldquo;not spam&rdquo; helps make sure future free guides land straight in your inbox.
        </p>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ formId, successId, errorId, listId }}>
  if (listId) {
    const form = document.getElementById(formId);
    const view = document.getElementById(`${formId}-view`);
    const success = document.getElementById(successId);
    const error = document.getElementById(errorId);

    if (form) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const emailInput = form.querySelector('input[type="email"]');
        const email = emailInput ? emailInput.value : '';
        const button = form.querySelector('button[type="submit"]');
        const originalText = button ? button.textContent : '';

        if (button) {
          button.disabled = true;
          button.textContent = 'Sending…';
        }
        if (error) {
          error.classList.add('hidden');
        }

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, listId }),
          });
          const data = await res.json().catch(() => ({}));

          if (res.ok && data.success) {
            if (view) view.style.display = 'none';
            if (success) success.classList.remove('hidden');
            return;
          }

          if (button) {
            button.disabled = false;
            button.textContent = originalText;
          }
          if (error) {
            error.textContent = data.error || 'Something went wrong. Please try again.';
            error.classList.remove('hidden');
          }
        } catch {
          if (button) {
            button.disabled = false;
            button.textContent = originalText;
          }
          if (error) {
            error.textContent = 'Could not reach the server. Check your connection and try again.';
            error.classList.remove('hidden');
          }
        }
      });
    }
  }
</script>
