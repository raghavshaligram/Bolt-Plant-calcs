---
// LeadMagnet opt-in. Two variants:
// - "full":    card with heading, description, email form, privacy note
// - "compact": single-line inline form for placement deeper in the page
//
// Props:
//   headline   — override the card heading (default: "Get the free Soil Cheat Sheet")
//   clusterTag — MailerLite tag to attach to the signup (default: "soil-cluster")
//   variant    — "full" | "compact" (default: "full")

export interface Props {
  variant?: 'full' | 'compact';
  /** Override the opt-in headline. */
  headline?: string;
  /** MailerLite group/tag identifier sent as a hidden field. */
  clusterTag?: string;
}

const {
  variant = 'full',
  headline = 'Get the free Soil & Raised Bed Mix Cheat Sheet',
  clusterTag = 'soil-cluster',
} = Astro.props;

const inputIdSuffix = variant === 'compact' ? '-compact' : '';
const emailInputId = `lead-magnet-email${inputIdSuffix}-${clusterTag}`;
---

{variant === 'full' ? (
  <div class="card my-10 border-moss-200/60 bg-moss-50/40">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="max-w-md">
        <h3 class="font-display text-lg font-semibold text-bark-900">
          {headline}
        </h3>
        <p class="mt-1 text-sm text-bark-600">
          A one-page PDF with the soil, mulch, and fertilizer math from this site &mdash; so you don&rsquo;t have to do it in the store aisle. Emailed once, no follow-up spam.
        </p>
      </div>
      <form
        class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row sm:shrink-0"
        aria-label={`${headline} signup`}
      >
        <input type="hidden" name="cluster_tag" value={clusterTag} />
        <label for={emailInputId} class="sr-only">Email address</label>
        <input
          id={emailInputId}
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="w-full rounded-lg border-0 bg-white px-3.5 py-2.5 text-sm text-bark-900 shadow-sm ring-1 ring-inset ring-bark-200 placeholder:text-bark-400 focus:ring-2 focus:ring-inset focus:ring-moss-500 sm:w-64"
        />
        <button type="submit" class="btn-primary shrink-0">Get the cheat sheet</button>
      </form>
    </div>
    <p class="mt-3 text-xs text-bark-500">
      One email with the PDF. No newsletter list. By signing up, you agree to our{' '}
      <a href="/privacy-policy/" class="text-moss-700 underline hover:text-moss-800">Privacy Policy</a>.
    </p>
  </div>
) : (
  <div class="my-8 rounded-xl border border-moss-100 bg-moss-50/30 p-4">
    <p class="text-sm text-bark-700">
      <strong class="font-semibold text-bark-900">Want the cheat sheet?</strong>{' '}
      A one-page PDF of the math from this site, emailed once.
    </p>
    <form
      class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center"
      aria-label={`${headline} signup`}
    >
      <input type="hidden" name="cluster_tag" value={clusterTag} />
      <label for={emailInputId} class="sr-only">Email address</label>
      <input
        id={emailInputId}
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        class="w-full rounded-lg border-0 bg-white px-3 py-2 text-sm text-bark-900 shadow-sm ring-1 ring-inset ring-bark-200 placeholder:text-bark-400 focus:ring-2 focus:ring-inset focus:ring-moss-500 sm:w-56"
      />
      <button type="submit" class="btn-primary shrink-0 text-xs">Get it</button>
    </form>
    <p class="mt-1.5 text-xs text-bark-500">
      No spam. See <a href="/privacy-policy/" class="text-moss-700 underline hover:text-moss-800">Privacy Policy</a>.
    </p>
  </div>
)}
