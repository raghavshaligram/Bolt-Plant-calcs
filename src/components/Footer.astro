---
import { clusters } from '../data/calculators';

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-moss-100 bg-moss-50/60">
  <div class="container-wide py-14">
    <div class="grid gap-10 lg:grid-cols-3">
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-moss-800">
          <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path d="M16 4c-3 4-5 7-5 11a5 5 0 0 0 10 0c0-4-2-7-5-11Z" fill="currentColor" />
            <path d="M16 26c-2-3-4-5-4-8a4 4 0 0 1 8 0c0 3-2 5-4 8Z" fill="currentColor" opacity="0.6" />
            <path d="M6 22c4 0 7 1 9 3M26 22c-4 0-7 1-9 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span class="font-display text-lg font-semibold">HarvestMath</span>
        </a>
        <p class="mt-3 max-w-xs text-sm text-bark-600">
          Free, fast, mobile-friendly calculators for gardeners, landscapers, and houseplant lovers. No sign-up, no fluff.
        </p>
      </div>

      <div class="lg:col-span-2">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-bark-500">Calculator clusters</h2>
        <ul class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
          {clusters.map((cluster) => (
            <li>
              <a href={`/clusters/${cluster.slug}/`} class="text-sm text-bark-700 transition hover:text-moss-800">
                {cluster.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-moss-100 pt-6 text-sm text-bark-500 sm:flex-row sm:items-center">
      <p>&copy; {year} HarvestMath. All calculators are estimates — verify before buying materials.</p>
      <div class="flex flex-wrap gap-x-4 gap-y-2">
        <a href="/blog/" class="hover:text-moss-800">Blog</a>
        <a href="/about/" class="hover:text-moss-800">About</a>
        <a href="/methodology/" class="hover:text-moss-800">Methodology</a>
        <a href="/contact/" class="hover:text-moss-800">Contact</a>
        <a href="/privacy-policy/" class="hover:text-moss-800">Privacy Policy</a>
        <a href="/affiliate-disclosure/" class="hover:text-moss-800">Affiliate Disclosure</a>
      </div>
    </div>
  </div>
</footer>
