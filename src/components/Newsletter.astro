---

<form class="mt-4 flex flex-col gap-2 sm:flex-row" aria-label="Newsletter signup">
  <label for="newsletter-email" class="sr-only">Email address</label>
  <input
    id="newsletter-email"
    type="email"
    required
    placeholder="you@example.com"
    class="w-full rounded-lg border-0 bg-white px-3.5 py-2.5 text-sm text-bark-900 shadow-sm ring-1 ring-inset ring-bark-200 placeholder:text-bark-400 focus:ring-2 focus:ring-inset focus:ring-moss-500"
  />
  <button type="submit" class="btn-primary shrink-0">Subscribe</button>
</form>
<p class="mt-2 text-xs text-bark-500">
  One email a month. Unsubscribe anytime. By subscribing, you agree to our <a href="/privacy-policy/" class="text-moss-700 underline hover:text-moss-800">Privacy Policy</a>.
</p>
