---
// CalculatorCard — the visual shell every calculator tool sits inside.
// Provides the rounded card, moss-green header band, and consistent padding.
// The calculator's interactive content goes in the default slot.
//
// Usage:
//   <CalculatorCard title="Calculate Your Soil Needs">
//     <!-- calculator inputs, results, tables … -->
//   </CalculatorCard>

export interface Props {
  /** Heading shown in the dark card header band. */
  title: string;
}

const { title } = Astro.props;
---

<div class="not-prose overflow-hidden rounded-2xl bg-white shadow-card ring-1 ring-moss-100/60">
  <div class="bg-moss-700 px-6 py-4">
    <h2 class="font-display text-lg font-semibold text-white">{title}</h2>
  </div>
  <div class="flex flex-col gap-5 p-6">
    <slot />
  </div>
</div>
